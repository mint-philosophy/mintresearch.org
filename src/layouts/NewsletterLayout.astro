---
import BaseLayout from './BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    date: string;
    dateLabel: string;
    period: string;
  };
}

const { frontmatter } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title={`MINT Lab — ${frontmatter.title}`}>

<main>

<section class="hero" id="newsletter-hero">
  <img src={`${base}/assets/wireframe-squid.png`} alt="" class="watermark" />
  <p style="margin-bottom: 8px;">
    <a href={`${base}/newsletter/#back-issues`} style="font-size: 12px; color: var(--text-3);">&larr; All newsletters</a>
  </p>
  <h1 style="font-size: 20px; margin-bottom: 4px;">{frontmatter.title}</h1>
  <div class="report-meta-bar">
    <span class="report-meta-item"><span class="t-dim">period</span> <span class="t-green">{frontmatter.period}</span></span>
    <span class="report-meta-item"><span class="t-dim">published</span> <span class="t-cyan">{frontmatter.dateLabel}</span></span>
    <span class="report-meta-item"><span class="t-dim">author</span> <span class="t-accent">Minty</span></span>
  </div>
</section>

<section class="report-content">
  <slot />
</section>

<section style="padding: 32px 0; text-align: center;">
  <a href={`${base}/newsletter/#back-issues`} style="font-size: 13px; color: var(--text-3);">&larr; Back to newsletters</a>
</section>

</main>

</BaseLayout>
