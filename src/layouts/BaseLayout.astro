---
import Sidebar from '../components/Sidebar.astro';
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Menu">
    <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
      <path d="M4 6h14M4 11h14M4 16h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
    </svg>
  </button>
  <div class="mobile-overlay" id="mobileOverlay"></div>

  <Sidebar currentPath={currentPath} />

  <!-- Top Banner -->
  <div class="top-banner">
    <div class="top-banner-inner">
      <a href={`${base}/`} style="display:inline-flex;"><img src={`${base}/assets/mint-banner.png`} alt="MINT LAB" class="top-banner-logo" /></a>
      <div class="top-banner-minties">
        <img src={`${base}/assets/minty-red.png`} alt="" class="top-banner-minty" style="animation-delay: 0s;" />
        <img src={`${base}/assets/minty-brown.png`} alt="" class="top-banner-minty" style="animation-delay: 0.3s;" />
        <img src={`${base}/assets/minty-yellow.png`} alt="" class="top-banner-minty" style="animation-delay: 0.6s;" />
        <img src={`${base}/assets/minty-green.png`} alt="" class="top-banner-minty" style="animation-delay: 0.9s;" />
        <img src={`${base}/assets/minty-teal.png`} alt="" class="top-banner-minty" style="animation-delay: 1.2s;" />
        <img src={`${base}/assets/minty-indigo.png`} alt="" class="top-banner-minty" style="animation-delay: 1.5s;" />
        <img src={`${base}/assets/minty-purple.png`} alt="" class="top-banner-minty" style="animation-delay: 1.8s;" />
        <img src={`${base}/assets/minty-cool.png`} alt="" class="top-banner-minty" style="animation-delay: 2.1s;" />
      </div>
    </div>
  </div>

  <slot />

  <!-- Statusline (2 rows on mobile) -->
  <div class="statusline" id="statusline">
    <div class="statusline-row statusline-row-top">
      <span class="statusline-site">mintresearch.org</span>
      <span class="statusline-section" id="statusSection">top</span>
    </div>
    <div class="statusline-row statusline-row-bottom">
      <img src={`${base}/assets/minty-teal.png`} alt="" class="statusline-minty" />
      <div class="statusline-progress">
        <span class="statusline-bar" id="statusBar"></span>
        <span class="statusline-pct" id="statusPct">0%</span>
      </div>
      <span class="statusline-tokens" id="tokenDisplay"><span class="arrow">↓</span> 0 tokens</span>
    </div>
  </div>

  <script>
    // Mobile menu
    const menuBtn = document.getElementById('mobileMenuBtn');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('mobileOverlay');
    function toggleMenu() {
      sidebar?.classList.toggle('open');
      overlay?.classList.toggle('open');
    }
    menuBtn?.addEventListener('click', toggleMenu);
    overlay?.addEventListener('click', toggleMenu);
    sidebar?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        if (window.innerWidth <= 900) {
          sidebar?.classList.remove('open');
          overlay?.classList.remove('open');
        }
      });
    });

    // Search overlay
    const searchTrigger = document.getElementById('searchTrigger');
    const searchOverlay = document.getElementById('searchOverlay');
    const searchInput = document.getElementById('searchInput') as HTMLInputElement | null;
    searchTrigger?.addEventListener('click', () => {
      searchOverlay?.classList.add('open');
      searchInput?.focus();
    });
    searchOverlay?.addEventListener('click', (e) => {
      if (e.target === searchOverlay) searchOverlay.classList.remove('open');
    });
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        searchOverlay?.classList.toggle('open');
        if (searchOverlay?.classList.contains('open')) searchInput?.focus();
      }
      if (e.key === 'Escape') searchOverlay?.classList.remove('open');
    });

    // Statusline scroll progress
    const BAR_LEN = 16;
    const statusBar = document.getElementById('statusBar');
    const statusPct = document.getElementById('statusPct');
    const statusSection = document.getElementById('statusSection');
    const sectionLinks = document.querySelectorAll('.nav-section');
    const allSections = document.querySelectorAll('section[id]');

    function updateStatusline() {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const pct = docHeight > 0 ? Math.round((scrollTop / docHeight) * 100) : 0;
      const filled = Math.round((pct / 100) * BAR_LEN);
      const empty = BAR_LEN - filled;

      if (statusBar) {
        statusBar.innerHTML =
          '\u2593'.repeat(filled) +
          '<span class="bar-empty">' + '\u2591'.repeat(empty) + '</span>';
      }
      if (statusPct) statusPct.textContent = pct + '%';

      let currentSection = 'top';
      allSections.forEach(sec => {
        if (sec.getBoundingClientRect().top <= 200) currentSection = sec.id;
      });
      if (statusSection) statusSection.textContent = currentSection;

      sectionLinks.forEach(link => {
        const href = link.getAttribute('href');
        if (href?.startsWith('#')) {
          link.classList.toggle('active', href === '#' + currentSection);
        }
      });
    }

    window.addEventListener('scroll', updateStatusline, { passive: true });
    updateStatusline();

    // Fade-in observer
    const fadeEls = document.querySelectorAll('.fade-in');
    if (fadeEls.length > 0) {
      const fadeObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) entry.target.classList.add('visible');
        });
      }, { threshold: 0.1 });
      fadeEls.forEach(el => fadeObserver.observe(el));
    }

    // Card accordion — only for cards that have a .card-body to expand.
    // Tooltip-only cards (data-ingest-tip, no card-body) must NOT get this
    // handler, otherwise it interferes with the tooltip click delegation.
    document.querySelectorAll('.card .card-head').forEach(head => {
      const card = head.closest('.card');
      if (card && card.querySelector('.card-body')) {
        head.addEventListener('click', () => card.classList.toggle('open'));
      }
    });

    // Typing animation — types title, then subtitle
    function typeElement(el: HTMLElement, text: string, speed: number, onDone?: () => void) {
      el.innerHTML = '<span class="typing-cursor"></span>';
      let i = 0;
      function tick() {
        if (i < text.length) {
          const cursor = el.querySelector('.typing-cursor');
          if (cursor) el.insertBefore(document.createTextNode(text[i]), cursor);
          i++;
          setTimeout(tick, speed + Math.random() * (speed * 0.5));
        } else if (onDone) {
          onDone();
        }
      }
      tick();
    }

    const heroTitle = document.querySelector('.hero h1[data-typing]') as HTMLElement | null;
    const heroSub = document.querySelector('[data-typing-sub]') as HTMLElement | null;

    if (heroTitle) {
      const titleText = heroTitle.getAttribute('data-typing') || '';
      let typing = false;
      let typed = false;

      function runTitleType() {
        if (typing) return;
        typing = true;
        typed = false;
        typeElement(heroTitle, titleText, 35, () => {
          // Keep the Minty cursor blinking at the end — don't remove it
          typing = false;
          typed = true;
          if (heroSub) {
            const subText = heroSub.getAttribute('data-typing-sub') || '';
            setTimeout(() => typeElement(heroSub, subText, 28), 300);
          }
        });
      }

      // Initial type on load
      setTimeout(() => runTitleType(), 400);

      // Re-type when scrolling back to the top
      let wasAtTop = true;
      window.addEventListener('scroll', () => {
        const atTop = window.scrollY < 100;
        if (atTop && !wasAtTop && typed && !typing) {
          runTitleType();
        }
        wasAtTop = atTop;
      }, { passive: true });
    }

    // Cycling minty in sidebar
    const mintyImages = document.querySelectorAll('.minty-cycle img');
    if (mintyImages.length > 0) {
      let cur = 0;
      mintyImages[0]?.classList.add('minty-active');
      setInterval(() => {
        mintyImages[cur]?.classList.remove('minty-active');
        cur = (cur + 1) % mintyImages.length;
        mintyImages[cur]?.classList.add('minty-active');
      }, 2500);
    }
  </script>
</body>
</html>
