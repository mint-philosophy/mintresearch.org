---
import { siteNav } from '../data/navigation';
import type { SectionLink } from '../data/navigation';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const cleanPath = (currentPath || "/").startsWith(base)
  ? (currentPath || "/").slice(base.length) || "/"
  : (currentPath || "/");

function isActivePage(pagePath: string): boolean {
  if (pagePath === "/") return cleanPath === "/" || cleanPath === "";
  return cleanPath.startsWith(pagePath);
}

---

<nav class="sidebar" id="sidebar">
  <a href={base + "/"} class="sidebar-header" style="text-decoration:none;">
    <span class="sidebar-title">MINT</span>
    <span class="sidebar-sub">Research Lab</span>
  </a>

  <div class="search-trigger" id="searchTrigger">
    <span>&#128269;</span> Search... <kbd>&#8984;K</kbd>
  </div>

  <div class="nav-pages">
    {siteNav.map((page) => {
      const active = isActivePage(page.path);
      return (
        <>
          <a class:list={["nav-link", "nav-page", { active }]} href={base + page.path}>
            <span class="nav-mark">{active ? '❯' : '▸'}</span>
            {page.label}
          </a>
          {page.sections.length > 0 && (
            <div class:list={["nav-sections", { expanded: active }]}>
              {page.sections.map((section: SectionLink, idx: number) => {
                const isLast = idx === page.sections.length - 1 && !section.children?.length;
                return (
                  <>
                    {section.divider && <div class="nav-divider">{section.divider}</div>}
                    <a class="nav-link nav-section" href={active ? section.href : base + page.path + section.href}>
                      <span class="nav-mark">{isLast ? '└──' : '├──'}</span>
                      {section.label}
                    </a>
                    {section.children?.map((child: SectionLink, ci: number) => (
                      <a class="nav-link nav-section sub-link" href={active ? child.href : base + page.path + child.href}>
                        <span class="nav-mark">{ci === (section.children?.length || 0) - 1 ? '└──' : '├──'}</span>
                        {child.label}
                      </a>
                    ))}
                  </>
                );
              })}
            </div>
          )}
        </>
      );
    })}
  </div>
</nav>

<div class="search-overlay" id="searchOverlay">
  <div class="search-box">
    <input type="text" id="searchInput" placeholder="$ grep -r 'query' ./corpus/">
    <div class="search-results" id="searchResults"></div>
  </div>
</div>
