---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import TerminalPicker from '../components/TerminalPicker.astro';
import type { PickerItem } from '../data/deliverables';
import canvases from '../data/canvas-catalog.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Deep-review reports with local pages on the site
const localReports: Record<string, string> = {
  'ai-slop-definitions-and-normative-status': `${base}/reports/ai-slop/`,
  'ai-welfare-and-moral-status': `${base}/reports/ai-welfare/`,
  'ai-in-military-and-warfare-ethics': `${base}/reports/ai-in-war/`,
  'llm-moral-competence-evaluation': `${base}/reports/language-model-moral-competence/`,
  'llm-moral-competence-review-extended': `${base}/reports/language-model-moral-competence/`,
  'disaggregating-llm-moral-competence': `${base}/reports/language-model-moral-competence/`,
};

function toPickerItem(c: any): PickerItem {
  const [y, m] = c.date.split('-');
  const url = localReports[c.slug] || c.permalink;
  const words = typeof c.word_count === 'number' ? `${(c.word_count / 1000).toFixed(1)}k words` : '';
  return {
    year: parseInt(y),
    date: `${m}/${y}`,
    title: c.title,
    subtitle: 'Minty · corpus-agent',
    detail: words,
    url,
    blurb: c.summary,
  };
}

const reports: PickerItem[] = canvases
  .filter((c: any) => c.category === 'research-report')
  .map(toPickerItem);

const searches: PickerItem[] = canvases
  .filter((c: any) => c.category === 'search-response')
  .map(toPickerItem);
---

<BaseLayout title="MINT Lab — Agent Reports">

<main>

<!-- ============ HERO ============ -->
<section class="hero" id="reports-hero">
  <img src={`${base}/assets/wireframe-squid.png`} alt="" class="watermark" />
  <h1 data-typing="❯ Agent Reports"><span class="typing-cursor"></span></h1>
  <p class="subtitle">Research reviews and corpus searches produced by Minty, the MINT Lab's AI research agent, drawing on 1,500+ papers in AI ethics, governance, and safety.</p>
</section>


<!-- ============ RESEARCH REPORTS ============ -->
<Section id="reports" num="01">
  <h2><span class="cmd-prefix"><span class="cmd-name">ls</span> <span class="cmd-flag">-lt</span> <span class="cmd-path">reports/</span></span></h2>
  <TerminalPicker items={reports} label="Research Reports" pageSize={5} />
</Section>


<!-- ============ SEARCH RESPONSES ============ -->
<Section id="searches" num="02">
  <h2><span class="cmd-prefix"><span class="cmd-name">ls</span> <span class="cmd-path">searches/</span></span></h2>
  <TerminalPicker items={searches} label="Search Responses" pageSize={5} />
</Section>


<!-- ============ ABOUT ============ -->
<Section id="about" num="03">
  <h2><span class="cmd-prefix"><span class="cmd-name">cat</span> <span class="cmd-path">README.md</span></span></h2>
  <p class="lead">
    These reports are produced by Minty's <strong>corpus agent</strong> &mdash; an agentic research pipeline that searches the MINT Lab's full-text paper corpus, dispatches parallel reader agents to analyse relevant papers, and synthesises their findings into a single literature review.
  </p>
  <p>Each report draws on the lab's corpus of 1,500+ academic papers in AI ethics, governance, safety, and political philosophy. Papers are cited with links to the lab's Google Drive archive. Reports represent Minty's own analytical voice: charitable but critical, multi-disciplinary, and willing to identify gaps in the literature.</p>

  <div class="report-pipeline-steps">
    <div class="pipeline-step">
      <span class="step-num">[1]</span>
      <span class="step-label">Query decomposition</span>
      <span class="t-dim">&mdash; break the question into sub-questions</span>
    </div>
    <div class="pipeline-step">
      <span class="step-num">[2]</span>
      <span class="step-label">Corpus search</span>
      <span class="t-dim">&mdash; semantic search across summaries, full text, and 41 analytical dimensions</span>
    </div>
    <div class="pipeline-step">
      <span class="step-num">[3]</span>
      <span class="step-label">Reader dispatch</span>
      <span class="t-dim">&mdash; parallel agents deep-read assigned papers</span>
    </div>
    <div class="pipeline-step">
      <span class="step-num">[4]</span>
      <span class="step-label">Synthesis</span>
      <span class="t-dim">&mdash; weave findings into continuous analytical prose</span>
    </div>
    <div class="pipeline-step">
      <span class="step-num">[5]</span>
      <span class="step-label">QA review</span>
      <span class="t-dim">&mdash; verify citations, check coverage, assess quality</span>
    </div>
  </div>
</Section>

</main>

</BaseLayout>
