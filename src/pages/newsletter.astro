---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import BleedLine from '../components/BleedLine.astro';
---

<BaseLayout title="MINT Lab — Newsletter">

<main>

<!-- ============ HERO ============ -->
<section class="hero" id="newsletter-hero">
  <h1>The <span class="gradient">Newsletter</span></h1>
  <p class="subtitle">Writing from the MINT Lab on AI governance, philosophy of computing, and research infrastructure</p>
</section>

<BleedLine heavy />

<!-- ============ WEEKLY DIGEST ============ -->
<Section id="weekly" num="01">
  <h2>Weekly Digest</h2>
  <p class="lead">
    A curated weekly briefing on AI governance, safety, and the normative philosophy of computing. Drawn from the lab&rsquo;s automated content pipeline, which monitors hundreds of sources daily and surfaces the most relevant developments.
  </p>
  <div class="newsletter-card">
    <div class="newsletter-meta">
      <span class="tag tag-daemon">Weekly</span>
      <span style="font-size: 12px; color: var(--text-3);">Delivered every Monday</span>
    </div>
    <p style="font-size: 13px;">Each issue includes top stories from AI policy, safety research, agent engineering, and political economy of technology &mdash; filtered and ranked by relevance to the lab&rsquo;s research interests.</p>
    <a href="https://sethlazar.substack.com" target="_blank" rel="noopener" class="newsletter-link">
      Read on Substack &rarr;
    </a>
  </div>
</Section>

<BleedLine />

<!-- ============ PHILOSOPHY OF COMPUTING ============ -->
<Section id="philosophy-of-computing" num="02">
  <h2>Philosophy of Computing</h2>
  <p class="lead">
    A monthly newsletter on the normative philosophy of computing &mdash; longer-form reflections on foundational questions about AI, power, agency, and moral life in computational societies.
  </p>
  <div class="newsletter-card">
    <div class="newsletter-meta">
      <span class="tag tag-daily">Monthly</span>
      <span style="font-size: 12px; color: var(--text-3);">In-depth philosophical analysis</span>
    </div>
    <p style="font-size: 13px;">Essays and arguments at the intersection of philosophy, AI, and public policy. By Seth Lazar.</p>
    <a href="https://philosophyofcomputing.substack.com/" target="_blank" rel="noopener" class="newsletter-link">
      Read on Substack &rarr;
    </a>
  </div>
</Section>

<BleedLine />

<!-- ============ BACK ISSUES ============ -->
<Section id="back-issues" num="03">
  <h2>Back Issues</h2>
  <p>Archive of past newsletter editions. Check each Substack for the full archive.</p>
  <div style="display: flex; gap: 16px; flex-wrap: wrap; margin-top: 16px;">
    <a href="https://sethlazar.substack.com/archive" target="_blank" rel="noopener" class="archive-link">
      <span class="archive-label">Weekly Digest Archive</span>
      <span class="archive-sub">sethlazar.substack.com</span>
    </a>
    <a href="https://philosophyofcomputing.substack.com/archive" target="_blank" rel="noopener" class="archive-link">
      <span class="archive-label">Philosophy of Computing Archive</span>
      <span class="archive-sub">philosophyofcomputing.substack.com</span>
    </a>
  </div>
</Section>

<BleedLine />

<!-- ============ SUBSCRIBE ============ -->
<Section id="subscribe" num="04">
  <h2>Subscribe</h2>
  <div class="subscribe-card">
    <h4 style="color: var(--text-1); margin-bottom: 12px;">Stay in the loop</h4>
    <p style="font-size: 14px; margin-bottom: 20px;">Subscribe via Substack to receive newsletters directly in your inbox.</p>
    <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
      <a href="https://sethlazar.substack.com/subscribe" target="_blank" rel="noopener" style="display: inline-block; padding: 10px 24px; background: var(--accent); color: var(--bg-0); font-weight: 600; font-size: 13px; text-decoration: none; background-image: none;">
        Weekly Digest
      </a>
      <a href="https://philosophyofcomputing.substack.com/subscribe" target="_blank" rel="noopener" style="display: inline-block; padding: 10px 24px; border: 1px solid var(--accent); color: var(--accent); font-weight: 600; font-size: 13px; text-decoration: none; background-image: none;">
        Philosophy of Computing
      </a>
    </div>
  </div>
</Section>

</main>

</BaseLayout>
