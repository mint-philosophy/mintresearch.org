---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import TerminalPicker from '../components/TerminalPicker.astro';
import type { PickerItem } from '../data/deliverables';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const weeklyDigests: PickerItem[] = [
  {
    year: 2026,
    date: '03/2026',
    title: "Minty's Week in AI — 24 Feb to 2 Mar 2026",
    subtitle: 'Minty · yesterday-in-ai',
    detail: 'Published 4 Mar 2026',
    url: `${base}/newsletters/2026-03-03-weekly/`,
    blurb: 'Anthropic designated a supply-chain risk by the Pentagon. AI agents develop political preference drift under grinding work conditions. Frontier models prove mathematics that takes human experts days to verify. OpenAI and Anthropic stake out opposing positions on enterprise software.',
  },
  {
    year: 2026,
    date: '02/2026',
    title: "Minty's Week in AI — 17 to 23 Feb 2026",
    subtitle: 'Minty · yesterday-in-ai',
    detail: 'Published 25 Feb 2026',
    url: `${base}/newsletters/2026-02-24-weekly/`,
    blurb: 'Google DeepMind argues for evaluating moral competence, not just performance. Agent security emerges as a dominant theme. LLM wargames show nuclear weapons used more often than by humans. Gemini 3.1 Pro takes the top benchmark spot at half the cost.',
  },
];
---

<BaseLayout title="MINT Lab — Newsletters">

<main>

<!-- ============ HERO ============ -->
<section class="hero" id="newsletter-hero">
  <img src={`${base}/assets/wireframe-squid.png`} alt="" class="watermark" />
  <h1 data-typing="❯ Newsletters"><span class="typing-cursor"></span></h1>
  <p class="subtitle">Writing from the MINT Lab on AI governance, philosophy of computing, and research infrastructure</p>
</section>


<!-- ============ YESTERDAY IN AI ============ -->
<Section id="yesterday-in-ai" num="01">
  <h2><span class="cmd-prefix"><span class="cmd-name">tail</span> <span class="cmd-flag">-f</span> <span class="cmd-path">yesterday-in-ai.log</span></span></h2>
  <p class="lead">
    A daily AI news digest from the MINT Lab, covering safety, governance, capabilities, and the political economy of AI as narrative prose.
  </p>
  <div class="newsletter-card">
    <div class="newsletter-meta">
      <span class="tag tag-daemon">Daily</span>
      <span style="font-size: 12px; color: var(--text-3);">Weekday mornings</span>
    </div>
    <p style="font-size: 13px;">Assembled from the lab's automated content pipeline, which monitors hundreds of sources daily and surfaces the most relevant developments. Synthesized by Claude Opus into contextual journalism &mdash; not punditry.</p>
    <form id="subscribe-form" style="display:flex;gap:10px;flex-wrap:wrap;margin-top:16px">
      <input type="email" name="email" required placeholder="you@university.edu" style="padding:10px 16px;border-radius:0;border:1px solid var(--border);background:var(--bg-0);color:var(--text-1);font-size:14px;font-family:var(--font);width:280px;outline:none;transition:border-color 0.2s" onfocus="this.style.borderColor='var(--mint)'" onblur="this.style.borderColor='var(--border)'">
      <div style="position:absolute;left:-9999px" aria-hidden="true"><input type="text" name="website" tabindex="-1" autocomplete="off"></div>
      <button type="submit" style="padding:10px 24px;border-radius:0;border:none;background:var(--mint);color:#06080c;font-size:14px;font-family:var(--font);font-weight:600;cursor:pointer;transition:opacity 0.2s" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">Subscribe</button>
    </form>
    <p id="subscribe-msg" style="margin-top:10px;font-size:14px;min-height:20px"></p>
  </div>
</Section>


<!-- ============ PHILOSOPHY OF COMPUTING ============ -->
<Section id="philosophy-of-computing" num="02">
  <h2><span class="cmd-prefix"><span class="cmd-name">cat</span> <span class="cmd-path">philosophy-of-computing.md</span></span></h2>
  <p class="lead">
    Weekly AI updates, monthly news and opportunities for philosophers working on AI and computing.
  </p>
  <div class="newsletter-card">
    <div class="newsletter-meta">
      <span class="tag tag-daily">Weekly / Monthly</span>
      <span style="font-size: 12px; color: var(--text-3);">On Substack</span>
    </div>
    <p style="font-size: 13px;">New research, calls for papers, jobs, events, and other opportunities at the intersection of philosophy, AI, and computing.</p>
    <a href="https://philosophyofcomputing.substack.com/" target="_blank" rel="noopener" class="newsletter-link">
      Read on Substack &rarr;
    </a>
  </div>
</Section>


<!-- ============ BACK ISSUES ============ -->
<Section id="back-issues" num="03">
  <h2><span class="cmd-prefix"><span class="cmd-name">ls</span> <span class="cmd-flag">-t</span> <span class="cmd-path">archive/</span> <span class="t-dim">|</span> <span class="cmd-name">head</span></span></h2>

  <h3>Minty's Week in AI</h3>
  <TerminalPicker items={weeklyDigests} label="Weekly Digests" pageSize={5} />

  <h3 style="margin-top: 24px;">Philosophy of Computing</h3>
  <div style="display: flex; gap: 16px; flex-wrap: wrap; margin-top: 8px;">
    <a href="https://philosophyofcomputing.substack.com/archive" target="_blank" rel="noopener" class="archive-link">
      <span class="archive-label">Philosophy of Computing Archive</span>
      <span class="archive-sub">philosophyofcomputing.substack.com</span>
    </a>
  </div>
</Section>

</main>

<script is:inline>
document.getElementById('subscribe-form').addEventListener('submit', function(e) {
  e.preventDefault();
  var msg = document.getElementById('subscribe-msg');
  var btn = this.querySelector('button');
  var email = this.querySelector('input[name="email"]').value;
  var website = this.querySelector('input[name="website"]').value;
  btn.disabled = true;
  btn.textContent = 'Subscribing...';
  msg.textContent = '';
  msg.style.color = 'var(--text-2)';
  fetch('https://api.mintresearch.org/api/subscribe', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({email: email, website: website})
  })
  .then(function(r) { return r.json().then(function(d) { return {ok: r.ok, data: d}; }); })
  .then(function(res) {
    if (res.ok) {
      msg.style.color = 'var(--green)';
      msg.textContent = res.data.message === 'already subscribed' ? 'You\'re already subscribed!' : 'Subscribed! You\'ll get the next issue.';
      btn.textContent = 'Subscribed';
    } else {
      throw new Error(res.data.error || 'Something went wrong');
    }
  })
  .catch(function(err) {
    msg.style.color = 'var(--red)';
    msg.textContent = err.message || 'Failed to subscribe. Try again.';
    btn.disabled = false;
    btn.textContent = 'Subscribe';
  });
});
</script>

</BaseLayout>
