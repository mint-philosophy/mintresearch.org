---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="404 — Not Found">

<main>
<section class="hero" id="not-found" style="padding: 60px 24px 48px; position: relative; overflow: hidden;">

  <div class="four-oh-four-outer">
    <!-- Big 404 with scanlines -->
    <div class="four-oh-four-big">
      <span class="four-oh-four-num">404</span>
      <div class="four-oh-four-scanlines"></div>
    </div>

    <!-- Minty floating over the terminal -->
    <div class="four-oh-four-scene">
      <img src={`${base}/assets/wireframe-squid.png`} alt="" class="four-oh-four-squid" />

      <div class="four-oh-four-terminal">
        <div class="term-titlebar">
          <span class="term-dot" style="background:var(--red)"></span>
          <span class="term-dot" style="background:var(--yellow)"></span>
          <span class="term-dot" style="background:var(--green)"></span>
          <span class="term-title">minty — bash — 80×24</span>
        </div>
        <div class="term-body">
          <div class="term-line"><span class="t-green">seth@mint</span><span class="t-text3">:</span><span class="t-cyan">~</span><span class="t-text3">$</span> curl -I mintresearch.org<span class="t-text3">/this-page</span></div>
          <div class="term-line t-text3">HTTP/1.1 <span class="t-red">404 Not Found</span></div>
          <div class="term-line t-text3">server: github-pages</div>
          <div class="term-line t-text3">x-powered-by: <span class="t-cyan">minty/2.0</span></div>
          <div class="term-line t-text3">x-blame: <span class="t-purple">the squid did it</span></div>
          <div class="term-line">&nbsp;</div>
          <div class="term-line"><span class="t-green">seth@mint</span><span class="t-text3">:</span><span class="t-cyan">~</span><span class="t-text3">$</span> <span class="t-yellow">echo</span> "trying to find your page..."</div>
          <div class="term-line t-text3">trying to find your page...</div>
          <div class="term-line">&nbsp;</div>
          <div class="term-line"><span class="t-green">seth@mint</span><span class="t-text3">:</span><span class="t-cyan">~</span><span class="t-text3">$</span> cd <a href={`${base}/`} class="term-link">/home</a><span class="term-cursor"></span></div>
        </div>
      </div>
    </div>

    <div class="four-oh-four-hint">
      <span class="t-text3">Or try:</span>
      <a href={`${base}/`} class="hint-link">About the Lab</a>
      <span class="t-text3">·</span>
      <a href={`${base}/guide/`} class="hint-link">Infrastructure</a>
      <span class="t-text3">·</span>
      <a href={`${base}/corpus-map/`} class="hint-link">Corpus Map</a>
    </div>
  </div>

</section>
</main>

<style>
  .four-oh-four-outer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  /* ---- Giant 404 ---- */
  .four-oh-four-big {
    position: relative;
    overflow: hidden;
    line-height: 1;
  }
  .four-oh-four-num {
    font-size: clamp(80px, 20vw, 160px);
    font-weight: 800;
    color: transparent;
    -webkit-text-stroke: 2px var(--red);
    letter-spacing: 0.05em;
    opacity: 0.35;
  }
  .four-oh-four-scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0px, transparent 3px,
      rgba(0,0,0,0.25) 3px, rgba(0,0,0,0.25) 6px
    );
    pointer-events: none;
  }

  /* ---- Scene: squid + terminal ---- */
  .four-oh-four-scene {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    max-width: 640px;
    width: 100%;
  }

  .four-oh-four-squid {
    width: 140px;
    height: auto;
    flex-shrink: 0;
    opacity: 0.8;
    filter: drop-shadow(0 0 16px rgba(46,196,182,0.3));
    animation: squidFloat 4s ease-in-out infinite;
  }
  @keyframes squidFloat {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    25% { transform: translateY(-6px) rotate(1deg); }
    75% { transform: translateY(2px) rotate(-1deg); }
  }

  /* ---- Terminal window ---- */
  .four-oh-four-terminal {
    flex: 1;
    border: 1px dashed var(--accent-dim);
    background: var(--bg-0);
    overflow: hidden;
  }

  .term-titlebar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    background: var(--bg-2);
    border-bottom: 1px dashed var(--border);
  }
  .term-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    opacity: 0.7;
  }
  .term-title {
    margin-left: auto;
    font-size: 9px;
    color: var(--text-3);
  }

  .term-body {
    padding: 12px 14px;
  }

  .term-line {
    font-size: 12px;
    line-height: 1.7;
    white-space: nowrap;
  }

  .t-green { color: var(--green); }
  .t-cyan { color: var(--cyan); }
  .t-red { color: var(--red); font-weight: 700; }
  .t-yellow { color: var(--yellow); }
  .t-purple { color: var(--purple); }
  .t-text3 { color: var(--text-3); }

  .term-link {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px dashed var(--accent);
  }
  .term-link:hover { color: var(--accent-bright); border-color: var(--accent-bright); }

  .term-cursor {
    display: inline-block;
    width: 8px; height: 13px;
    background: var(--accent);
    margin-left: 2px;
    vertical-align: text-bottom;
    animation: blink 1s step-end infinite;
  }

  /* ---- Navigation hints ---- */
  .four-oh-four-hint {
    display: flex;
    gap: 8px;
    align-items: center;
    font-size: 12px;
    padding-top: 8px;
  }
  .hint-link {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px dashed transparent;
  }
  .hint-link:hover { border-color: var(--accent); }

  /* ---- Mobile ---- */
  @media (max-width: 600px) {
    .four-oh-four-scene {
      flex-direction: column;
      align-items: center;
    }
    .four-oh-four-squid { width: 100px; }
    .term-line { font-size: 10px; }
    .term-body { padding: 10px 12px; }
    .four-oh-four-hint { flex-wrap: wrap; justify-content: center; }
  }
</style>

</BaseLayout>
