---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Not Found">

<main>
<section class="hero" id="not-found" style="padding-top: 60px;">
  <img src={`${import.meta.env.BASE_URL}assets/minty-cool.png`} alt="Sunglasses Minty" style="width: 120px; height: 120px; image-rendering: pixelated; margin-bottom: 24px;" />
  <h1 style="font-size: 48px; color: var(--red);">404</h1>
  <p class="subtitle" style="margin-top: 12px;">
    <span style="color: var(--red);">bash: </span>page not found
  </p>
  <p style="color: var(--text-3); font-size: 12px; margin-top: 24px;">
    <span style="color: var(--green);">$</span> cd <a href={import.meta.env.BASE_URL} style="color: var(--accent);">/home</a>
  </p>
</section>
</main>

</BaseLayout>
