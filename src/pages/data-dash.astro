---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const floatingMinties = [
  { color: 'teal',   size: 120, top: '8%',  left: '3%',  delay: '0s',   duration: '8s'  },
  { color: 'green',  size: 90,  top: '60%', left: '2%',  delay: '1.5s', duration: '10s' },
  { color: 'purple', size: 110, top: '15%', right: '3%', delay: '0.8s', duration: '7s'  },
  { color: 'yellow', size: 80,  top: '70%', right: '2%', delay: '2.2s', duration: '9s'  },
  { color: 'indigo', size: 140, top: '40%', left: '1%',  delay: '3s',   duration: '11s' },
];
---

<BaseLayout title="Data Dash — MINT Lab">

<main class="data-dash-page">
  <!-- Floating Minties -->
  <div class="dd-floating-minties" aria-hidden="true">
    {floatingMinties.map((m, i) => (
      <img
        src={`${base}/assets/minty-${m.color}.png`}
        alt=""
        class={`dd-float-squid dd-float-squid-${i}`}
        style={`
          width: ${m.size}px;
          top: ${m.top};
          ${m.left ? `left: ${m.left}` : ''};
          ${m.right ? `right: ${m.right}` : ''};
          animation-delay: ${m.delay};
          animation-duration: ${m.duration};
        `}
      />
    ))}
  </div>

  <section class="dd-hero">
    <h1 data-typing="Data Dash"></h1>
    <p class="dd-sub" data-typing-sub="Navigate the platforms. Collect the papers. Fight the slop."></p>
  </section>

  <!-- Game Terminal Window -->
  <div class="dd-terminal">
    <div class="dd-term-titlebar">
      <span class="term-dot" style="background:var(--red)"></span>
      <span class="term-dot" style="background:var(--yellow)"></span>
      <span class="term-dot" style="background:var(--green)"></span>
      <span class="dd-term-title">data-dash — phaser — 800×500</span>
    </div>
    <div class="dd-term-body">
      <div id="game-container"></div>
    </div>
  </div>

  <!-- Controls hint -->
  <div class="dd-controls">
    <span class="dd-key">← → / A D</span> <span class="dd-ctrl-label">Move</span>
    <span class="dd-ctrl-sep">·</span>
    <span class="dd-key">↑ / W / Space</span> <span class="dd-ctrl-label">Jump</span>
    <span class="dd-ctrl-sep">·</span>
    <span class="dd-key">Z / X</span> <span class="dd-ctrl-label">Shoot Ink</span>
    <span class="dd-ctrl-sep">·</span>
    <span class="dd-key">ESC</span> <span class="dd-ctrl-label">Pause</span>
  </div>

  <!-- Mobile notice -->
  <div class="dd-mobile-notice">
    <p>Data Dash is best experienced on desktop with a keyboard.</p>
  </div>
</section>
</main>

<script>
  import { createGame } from '../game/index';

  // Only init game on desktop (or if container exists)
  const container = document.getElementById('game-container');
  if (container) {
    // Wait for the page to fully load
    if (document.readyState === 'complete') {
      createGame('game-container');
    } else {
      window.addEventListener('load', () => createGame('game-container'));
    }
  }
</script>

<style>
  .data-dash-page {
    position: relative;
    padding: 40px 24px 60px;
    max-width: 960px;
    margin: 0 auto;
    min-height: 100vh;
  }

  /* ---- Floating Minties ---- */
  .dd-floating-minties {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .dd-float-squid {
    position: absolute;
    opacity: 0.15;
    filter: drop-shadow(0 0 20px rgba(46, 196, 182, 0.3));
    animation-name: ddFloat;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
    animation-fill-mode: both;
  }

  .dd-float-squid-0 { animation-name: ddFloat0; }
  .dd-float-squid-1 { animation-name: ddFloat1; }
  .dd-float-squid-2 { animation-name: ddFloat2; }
  .dd-float-squid-3 { animation-name: ddFloat3; }
  .dd-float-squid-4 { animation-name: ddFloat4; }

  @keyframes ddFloat0 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    25% { transform: translate(15px, -20px) rotate(3deg); }
    50% { transform: translate(-10px, -35px) rotate(-2deg); }
    75% { transform: translate(20px, -15px) rotate(4deg); }
  }
  @keyframes ddFloat1 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(-20px, -25px) rotate(-5deg); }
    66% { transform: translate(15px, -40px) rotate(3deg); }
  }
  @keyframes ddFloat2 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    25% { transform: translate(-15px, 20px) rotate(-3deg); }
    50% { transform: translate(10px, -15px) rotate(5deg); }
    75% { transform: translate(-20px, -30px) rotate(-4deg); }
  }
  @keyframes ddFloat3 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    50% { transform: translate(25px, -35px) rotate(6deg); }
  }
  @keyframes ddFloat4 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    20% { transform: translate(-10px, -15px) rotate(-2deg); }
    40% { transform: translate(20px, -30px) rotate(4deg); }
    60% { transform: translate(-15px, -45px) rotate(-3deg); }
    80% { transform: translate(10px, -20px) rotate(2deg); }
  }

  /* ---- Hero ---- */
  .dd-hero {
    text-align: center;
    margin-bottom: 24px;
    position: relative;
    z-index: 1;
  }

  .dd-hero h1 {
    font-size: 28px;
    color: var(--accent);
    min-height: 1.3em;
  }

  .dd-sub {
    color: var(--text-2);
    font-size: 12px;
    margin-top: 8px;
    min-height: 1.7em;
  }

  /* ---- Terminal Game Window ---- */
  .dd-terminal {
    border: 1px dashed var(--accent-dim);
    background: var(--bg-0);
    overflow: hidden;
    position: relative;
    z-index: 1;
    max-width: 832px;
    margin: 0 auto;
  }

  .dd-term-titlebar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    background: var(--bg-2);
    border-bottom: 1px dashed var(--border);
  }

  .dd-term-title {
    margin-left: auto;
    font-size: 9px;
    color: var(--text-3);
  }

  .dd-term-body {
    padding: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 500px;
    background: #0a0a0a;
  }

  #game-container {
    width: 800px;
    height: 500px;
  }

  #game-container canvas {
    display: block;
    image-rendering: pixelated;
  }

  /* ---- Controls ---- */
  .dd-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 16px;
    font-size: 11px;
    color: var(--text-3);
    position: relative;
    z-index: 1;
  }

  .dd-key {
    background: var(--bg-3);
    padding: 2px 6px;
    border: 1px solid var(--border);
    color: var(--text-2);
    font-size: 10px;
  }

  .dd-ctrl-label {
    color: var(--text-3);
  }

  .dd-ctrl-sep {
    color: var(--text-3);
    opacity: 0.5;
  }

  /* ---- Mobile notice ---- */
  .dd-mobile-notice {
    display: none;
    text-align: center;
    margin-top: 24px;
    padding: 12px;
    border: 1px dashed var(--accent-dim);
    color: var(--text-2);
    font-size: 11px;
    position: relative;
    z-index: 1;
  }

  @media (max-width: 860px) {
    .dd-mobile-notice { display: block; }
    .dd-controls { flex-wrap: wrap; }
    #game-container { width: 100%; height: auto; aspect-ratio: 8/5; }
    .dd-term-body { min-height: auto; }
    .dd-float-squid { display: none; }
  }
</style>

</BaseLayout>
