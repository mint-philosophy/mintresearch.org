---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const floatingMinties = [
  // Teal ×3
  { color: 'teal',   size: 120, top: '8%',  left: '260px', delay: '0s',   duration: '8s'  },
  { color: 'teal',   size: 70,  top: '45%', right: '8%',   delay: '3.5s', duration: '11s' },
  { color: 'teal',   size: 95,  bottom: '15%', left: '280px', delay: '6s', duration: '9s' },
  // Green ×3
  { color: 'green',  size: 90,  top: '60%', left: '270px', delay: '1.5s', duration: '10s' },
  { color: 'green',  size: 60,  top: '5%',  right: '12%',  delay: '4s',   duration: '8s'  },
  { color: 'green',  size: 110, bottom: '25%', right: '6%', delay: '7s',  duration: '12s' },
  // Purple ×3
  { color: 'purple', size: 110, top: '15%', right: '3%',   delay: '0.8s', duration: '7s'  },
  { color: 'purple', size: 65,  top: '75%', left: '280px', delay: '4.5s', duration: '10s' },
  { color: 'purple', size: 85,  top: '35%', right: '15%',  delay: '2s',   duration: '9s'  },
  // Yellow ×3
  { color: 'yellow', size: 80,  top: '70%', right: '2%',   delay: '2.2s', duration: '9s'  },
  { color: 'yellow', size: 55,  top: '12%', left: '285px', delay: '5s',   duration: '11s' },
  { color: 'yellow', size: 100, bottom: '3%', left: '40%', delay: '1s',   duration: '8s'  },
  // Indigo ×3
  { color: 'indigo', size: 140, top: '40%', left: '265px', delay: '3s',   duration: '11s' },
  { color: 'indigo', size: 70,  bottom: '20%', right: '10%', delay: '0.3s', duration: '9s' },
  { color: 'indigo', size: 90,  top: '2%',  left: '35%',   delay: '5.5s', duration: '7s'  },
  // Red ×3
  { color: 'red',    size: 85,  top: '3%',  left: '45%',   delay: '0.5s', duration: '9s'  },
  { color: 'red',    size: 50,  top: '55%', right: '4%',   delay: '3.8s', duration: '10s' },
  { color: 'red',    size: 105, bottom: '10%', left: '30%', delay: '6.5s', duration: '8s' },
  // Cool ×3
  { color: 'cool',   size: 95,  bottom: '5%', left: '35%',  delay: '1.8s', duration: '8s'  },
  { color: 'cool',   size: 60,  top: '25%', left: '270px', delay: '4.2s', duration: '12s' },
  { color: 'cool',   size: 75,  top: '80%', right: '12%',  delay: '0.2s', duration: '10s' },
  // Brown ×3
  { color: 'brown',  size: 75,  bottom: '8%', right: '5%',  delay: '2.5s', duration: '10s' },
  { color: 'brown',  size: 130, top: '20%', left: '275px', delay: '5.8s', duration: '9s'  },
  { color: 'brown',  size: 55,  top: '50%', right: '1%',   delay: '1.2s', duration: '11s' },
];
---

<BaseLayout title="Data Dash — MINT Lab">

<main class="data-dash-page">
  <!-- Floating Minties -->
  <div class="dd-floating-minties" aria-hidden="true">
    {floatingMinties.map((m, i) => (
      <img
        src={`${base}/assets/minty-${m.color}.png`}
        alt=""
        class={`dd-float-squid dd-float-squid-${i}`}
        style={`
          width: ${m.size}px;
          ${m.top ? `top: ${m.top};` : ''}
          ${m.left ? `left: ${m.left};` : ''}
          ${m.right ? `right: ${m.right};` : ''}
          ${m.bottom ? `bottom: ${m.bottom};` : ''}
          animation-delay: ${m.delay};
          animation-duration: ${m.duration};
        `}
      />
    ))}
  </div>

  <section class="dd-hero">
    <h1 data-typing="Data Dash"></h1>
    <p class="dd-sub" data-typing-sub="Navigate the platforms. Collect the papers. Fight the slop."></p>
  </section>

  <!-- Game Terminal Window -->
  <div class="dd-terminal">
    <div class="dd-term-titlebar">
      <span class="term-dot" style="background:var(--red)"></span>
      <span class="term-dot" style="background:var(--yellow)"></span>
      <span class="term-dot" style="background:var(--green)"></span>
      <span class="dd-term-title">data-dash — phaser — 800×500</span>
    </div>
    <div class="dd-term-body">
      <div id="game-container"></div>
    </div>
  </div>

  <!-- Controls hint -->
  <div class="dd-controls">
    <span class="dd-key">← → / A D</span> <span class="dd-ctrl-label">Move</span>
    <span class="dd-ctrl-sep">·</span>
    <span class="dd-key">↑ / W / Space</span> <span class="dd-ctrl-label">Jump</span>
    <span class="dd-ctrl-sep">·</span>
    <span class="dd-key">Z / X</span> <span class="dd-ctrl-label">Fire Paper</span>
    <span class="dd-ctrl-sep">·</span>
    <span class="dd-key">ESC</span> <span class="dd-ctrl-label">Pause</span>
  </div>

  <!-- Mobile notice -->
  <div class="dd-mobile-notice">
    <p>Data Dash is best experienced on desktop with a keyboard.</p>
  </div>
</section>
</main>

<script>
  import { createGame } from '../game/index';

  // Only init game on desktop (or if container exists)
  const container = document.getElementById('game-container');
  if (container) {
    // Wait for the page to fully load
    if (document.readyState === 'complete') {
      createGame('game-container');
    } else {
      window.addEventListener('load', () => createGame('game-container'));
    }
  }
</script>

<style>
  .data-dash-page {
    position: relative;
    padding: 40px 24px 60px;
    max-width: 960px;
    margin: 0 auto;
    min-height: 100vh;
  }

  /* ---- Floating Minties ---- */
  .dd-floating-minties {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .dd-float-squid {
    position: absolute;
    opacity: 0.2;
    filter: drop-shadow(0 0 20px rgba(46, 196, 182, 0.3));
    animation-name: ddFloat;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
    animation-fill-mode: both;
  }

  /* 24 squid animation classes, reusing 8 keyframes via modulo */
  .dd-float-squid-0  { animation-name: ddFloat0; }
  .dd-float-squid-1  { animation-name: ddFloat1; }
  .dd-float-squid-2  { animation-name: ddFloat2; }
  .dd-float-squid-3  { animation-name: ddFloat3; }
  .dd-float-squid-4  { animation-name: ddFloat4; }
  .dd-float-squid-5  { animation-name: ddFloat5; }
  .dd-float-squid-6  { animation-name: ddFloat6; }
  .dd-float-squid-7  { animation-name: ddFloat7; }
  .dd-float-squid-8  { animation-name: ddFloat0; }
  .dd-float-squid-9  { animation-name: ddFloat1; }
  .dd-float-squid-10 { animation-name: ddFloat2; }
  .dd-float-squid-11 { animation-name: ddFloat3; }
  .dd-float-squid-12 { animation-name: ddFloat4; }
  .dd-float-squid-13 { animation-name: ddFloat5; }
  .dd-float-squid-14 { animation-name: ddFloat6; }
  .dd-float-squid-15 { animation-name: ddFloat7; }
  .dd-float-squid-16 { animation-name: ddFloat0; }
  .dd-float-squid-17 { animation-name: ddFloat1; }
  .dd-float-squid-18 { animation-name: ddFloat2; }
  .dd-float-squid-19 { animation-name: ddFloat3; }
  .dd-float-squid-20 { animation-name: ddFloat4; }
  .dd-float-squid-21 { animation-name: ddFloat5; }
  .dd-float-squid-22 { animation-name: ddFloat6; }
  .dd-float-squid-23 { animation-name: ddFloat7; }

  @keyframes ddFloat0 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    25% { transform: translate(15px, -20px) rotate(3deg); }
    50% { transform: translate(-10px, -35px) rotate(-2deg); }
    75% { transform: translate(20px, -15px) rotate(4deg); }
  }
  @keyframes ddFloat1 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(-20px, -25px) rotate(-5deg); }
    66% { transform: translate(15px, -40px) rotate(3deg); }
  }
  @keyframes ddFloat2 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    25% { transform: translate(-15px, 20px) rotate(-3deg); }
    50% { transform: translate(10px, -15px) rotate(5deg); }
    75% { transform: translate(-20px, -30px) rotate(-4deg); }
  }
  @keyframes ddFloat3 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    50% { transform: translate(25px, -35px) rotate(6deg); }
  }
  @keyframes ddFloat4 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    20% { transform: translate(-10px, -15px) rotate(-2deg); }
    40% { transform: translate(20px, -30px) rotate(4deg); }
    60% { transform: translate(-15px, -45px) rotate(-3deg); }
    80% { transform: translate(10px, -20px) rotate(2deg); }
  }
  @keyframes ddFloat5 {
    0%, 100% { transform: translate(0, 0) rotate(0deg) scale(1); }
    30% { transform: translate(12px, -18px) rotate(4deg) scale(1.05); }
    60% { transform: translate(-8px, -28px) rotate(-3deg) scale(0.95); }
  }
  @keyframes ddFloat6 {
    0%, 100% { transform: translate(0, 0) rotate(0deg) scale(1); }
    40% { transform: translate(-15px, 12px) rotate(-4deg) scale(1.08); }
    70% { transform: translate(10px, -10px) rotate(3deg) scale(0.92); }
  }
  @keyframes ddFloat7 {
    0%, 100% { transform: translate(0, 0) rotate(0deg) scale(1); }
    25% { transform: translate(18px, 8px) rotate(5deg) scale(1.04); }
    50% { transform: translate(-12px, -20px) rotate(-5deg) scale(0.96); }
    75% { transform: translate(8px, 15px) rotate(2deg) scale(1.02); }
  }

  /* ---- Hero ---- */
  .dd-hero {
    text-align: center;
    margin-bottom: 24px;
    position: relative;
    z-index: 1;
  }

  .dd-hero h1 {
    font-size: 28px;
    color: var(--accent);
    min-height: 1.3em;
  }

  .dd-sub {
    color: var(--text-2);
    font-size: 12px;
    margin-top: 8px;
    min-height: 1.7em;
  }

  /* ---- Terminal Game Window ---- */
  .dd-terminal {
    border: 1px dashed var(--accent-dim);
    background: var(--bg-0);
    overflow: hidden;
    position: relative;
    z-index: 1;
    max-width: 832px;
    margin: 0 auto;
  }

  .dd-term-titlebar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    background: var(--bg-2);
    border-bottom: 1px dashed var(--border);
  }

  .dd-term-title {
    margin-left: auto;
    font-size: 9px;
    color: var(--text-3);
  }

  .dd-term-body {
    padding: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 500px;
    background: #0a0a0a;
  }

  #game-container {
    width: 800px;
    height: 500px;
  }

  #game-container canvas {
    display: block;
    image-rendering: pixelated;
  }

  /* ---- Controls ---- */
  .dd-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 16px;
    font-size: 11px;
    color: var(--text-3);
    position: relative;
    z-index: 1;
  }

  .dd-key {
    background: var(--bg-3);
    padding: 2px 6px;
    border: 1px solid var(--border);
    color: var(--text-2);
    font-size: 10px;
  }

  .dd-ctrl-label {
    color: var(--text-3);
  }

  .dd-ctrl-sep {
    color: var(--text-3);
    opacity: 0.5;
  }

  /* ---- Mobile notice ---- */
  .dd-mobile-notice {
    display: none;
    text-align: center;
    margin-top: 24px;
    padding: 12px;
    border: 1px dashed var(--accent-dim);
    color: var(--text-2);
    font-size: 11px;
    position: relative;
    z-index: 1;
  }

  @media (max-width: 860px) {
    .dd-mobile-notice { display: block; }
    .dd-controls { flex-wrap: wrap; }
    #game-container { width: 100%; height: auto; aspect-ratio: 8/5; }
    .dd-term-body { min-height: auto; }
    .dd-float-squid { display: none; }
  }
</style>

</BaseLayout>
