---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const floatingMinties = [
  { color: 'teal',   size: 120 }, { color: 'teal',   size: 70  }, { color: 'teal',   size: 95  },
  { color: 'green',  size: 90  }, { color: 'green',  size: 60  }, { color: 'green',  size: 110 },
  { color: 'purple', size: 110 }, { color: 'purple', size: 65  }, { color: 'purple', size: 85  },
  { color: 'yellow', size: 80  }, { color: 'yellow', size: 55  }, { color: 'yellow', size: 100 },
  { color: 'indigo', size: 140 }, { color: 'indigo', size: 70  }, { color: 'indigo', size: 90  },
  { color: 'red',    size: 85  }, { color: 'red',    size: 50  }, { color: 'red',    size: 105 },
  { color: 'cool',   size: 95  }, { color: 'cool',   size: 60  }, { color: 'cool',   size: 75  },
  { color: 'brown',  size: 75  }, { color: 'brown',  size: 130 }, { color: 'brown',  size: 55  },
];
---

<BaseLayout title="Data Dash — MINT Lab">

<main class="data-dash-page">
  <!-- Floating Minties -->
  <div class="dd-floating-minties" aria-hidden="true">
    {floatingMinties.map((m, i) => (
      <img
        src={`${base}/assets/minty-${m.color}.png`}
        alt=""
        class="dd-float-squid"
        data-squid-idx={i}
        style={`width: ${m.size}px;`}
      />
    ))}
  </div>

  <section class="dd-hero">
    <h1 data-typing="Data Dash"></h1>
    <p class="dd-sub" data-typing-sub="Navigate the platforms. Collect the papers. Fight the slop."></p>
  </section>

  <!-- Game Terminal Window -->
  <div class="dd-terminal">
    <div class="dd-term-titlebar">
      <span class="term-dot" style="background:var(--red)"></span>
      <span class="term-dot" style="background:var(--yellow)"></span>
      <span class="term-dot" style="background:var(--green)"></span>
      <span class="dd-term-title">data-dash — phaser — 800×500</span>
    </div>
    <div class="dd-term-body">
      <div id="game-container"></div>
    </div>
  </div>

  <!-- Controls hint -->
  <div class="dd-controls">
    <span class="dd-key">← → / A D</span> <span class="dd-ctrl-label">Move</span>
    <span class="dd-ctrl-sep">·</span>
    <span class="dd-key">↑ / W / Space</span> <span class="dd-ctrl-label">Jump</span>
    <span class="dd-ctrl-sep">·</span>
    <span class="dd-key">Z / X</span> <span class="dd-ctrl-label">Fire Paper</span>
    <span class="dd-ctrl-sep">·</span>
    <span class="dd-key">ESC</span> <span class="dd-ctrl-label">Pause</span>
  </div>

  <!-- Mobile notice -->
  <div class="dd-mobile-notice">
    <p>Data Dash is best experienced on desktop with a keyboard.</p>
  </div>
</section>
</main>

<script>
  import { createGame } from '../game/index';

  const container = document.getElementById('game-container');
  if (container) {
    if (document.readyState === 'complete') {
      createGame('game-container');
    } else {
      window.addEventListener('load', () => createGame('game-container'));
    }
  }

  // Random wandering Minties
  const squids = document.querySelectorAll<HTMLImageElement>('.dd-float-squid');
  const vw = () => window.innerWidth;
  const vh = () => window.innerHeight;

  squids.forEach((squid) => {
    const size = squid.offsetWidth || 80;
    // Random start position
    let x = Math.random() * (vw() - size);
    let y = Math.random() * (vh() - size);
    squid.style.left = `${x}px`;
    squid.style.top = `${y}px`;

    // Random rotation
    let rot = Math.random() * 10 - 5;

    function wander() {
      // Pick a new random destination anywhere on screen
      const tx = Math.random() * (vw() - size);
      const ty = Math.random() * (vh() - size);
      const newRot = Math.random() * 12 - 6;
      const dist = Math.hypot(tx - x, ty - y);
      // Duration proportional to distance (speed ~40-80px/s)
      const speed = 40 + Math.random() * 40;
      const dur = Math.max(3000, (dist / speed) * 1000);

      squid.style.transition = `left ${dur}ms ease-in-out, top ${dur}ms ease-in-out, transform ${dur}ms ease-in-out`;
      squid.style.left = `${tx}px`;
      squid.style.top = `${ty}px`;
      squid.style.transform = `rotate(${newRot}deg)`;

      x = tx;
      y = ty;
      rot = newRot;

      setTimeout(wander, dur + Math.random() * 2000);
    }

    // Stagger start
    setTimeout(wander, Math.random() * 4000);
  });
</script>

<style>
  .data-dash-page {
    position: relative;
    padding: 40px 24px 60px;
    max-width: 960px;
    margin: 0 auto;
    min-height: 100vh;
  }

  /* ---- Floating Minties ---- */
  .dd-floating-minties {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .dd-float-squid {
    position: absolute;
    opacity: 0.18;
    filter: drop-shadow(0 0 20px rgba(46, 196, 182, 0.3));
    will-change: left, top, transform;
  }

  /* ---- Hero ---- */
  .dd-hero {
    text-align: center;
    margin-bottom: 24px;
    position: relative;
    z-index: 1;
  }

  .dd-hero h1 {
    font-size: 28px;
    color: var(--accent);
    min-height: 1.3em;
  }

  .dd-sub {
    color: var(--text-2);
    font-size: 12px;
    margin-top: 8px;
    min-height: 1.7em;
  }

  /* ---- Terminal Game Window ---- */
  .dd-terminal {
    border: 1px dashed var(--accent-dim);
    background: var(--bg-0);
    overflow: hidden;
    position: relative;
    z-index: 1;
    max-width: 832px;
    margin: 0 auto;
  }

  .dd-term-titlebar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    background: var(--bg-2);
    border-bottom: 1px dashed var(--border);
  }

  .dd-term-title {
    margin-left: auto;
    font-size: 9px;
    color: var(--text-3);
  }

  .dd-term-body {
    padding: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 500px;
    background: #0a0a0a;
  }

  #game-container {
    width: 800px;
    height: 500px;
  }

  #game-container canvas {
    display: block;
    image-rendering: pixelated;
  }

  /* ---- Controls ---- */
  .dd-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 16px;
    font-size: 11px;
    color: var(--text-3);
    position: relative;
    z-index: 1;
  }

  .dd-key {
    background: var(--bg-3);
    padding: 2px 6px;
    border: 1px solid var(--border);
    color: var(--text-2);
    font-size: 10px;
  }

  .dd-ctrl-label {
    color: var(--text-3);
  }

  .dd-ctrl-sep {
    color: var(--text-3);
    opacity: 0.5;
  }

  /* ---- Mobile notice ---- */
  .dd-mobile-notice {
    display: none;
    text-align: center;
    margin-top: 24px;
    padding: 12px;
    border: 1px dashed var(--accent-dim);
    color: var(--text-2);
    font-size: 11px;
    position: relative;
    z-index: 1;
  }

  @media (max-width: 860px) {
    .dd-mobile-notice { display: block; }
    .dd-controls { flex-wrap: wrap; }
    #game-container { width: 100%; height: auto; aspect-ratio: 8/5; }
    .dd-term-body { min-height: auto; }
    .dd-float-squid { display: none; }
  }
</style>

</BaseLayout>
