---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const floatingMinties = [
  { color: 'teal',   size: 120 }, { color: 'teal',   size: 70  }, { color: 'teal',   size: 95  },
  { color: 'green',  size: 90  }, { color: 'green',  size: 60  }, { color: 'green',  size: 110 },
  { color: 'purple', size: 110 }, { color: 'purple', size: 65  }, { color: 'purple', size: 85  },
  { color: 'yellow', size: 80  }, { color: 'yellow', size: 55  }, { color: 'yellow', size: 100 },
  { color: 'indigo', size: 140 }, { color: 'indigo', size: 70  }, { color: 'indigo', size: 90  },
  { color: 'red',    size: 85  }, { color: 'red',    size: 50  }, { color: 'red',    size: 105 },
  { color: 'cool',   size: 95  }, { color: 'cool',   size: 60  }, { color: 'cool',   size: 75  },
  { color: 'brown',  size: 75  }, { color: 'brown',  size: 130 }, { color: 'brown',  size: 55  },
];
---

<BaseLayout title="Data Dash — MINT Lab">

<main class="data-dash-page">
  <!-- Floating Minties -->
  <div class="dd-floating-minties" aria-hidden="true">
    {floatingMinties.map((m, i) => (
      <img
        src={`${base}/assets/minty-${m.color}.png`}
        alt=""
        class="dd-float-squid"
        data-squid-idx={i}
        style={`width: ${m.size}px;`}
      />
    ))}
  </div>

  <section class="dd-hero">
    <h1 data-typing="Data Dash"></h1>
    <p class="dd-sub" data-typing-sub="Navigate the platforms. Collect the papers. Fight the slop."></p>
  </section>

  <!-- Game Terminal Window -->
  <div class="dd-terminal">
    <div class="dd-term-titlebar">
      <span class="term-dot" style="background:var(--red)"></span>
      <span class="term-dot" style="background:var(--yellow)"></span>
      <span class="term-dot" style="background:var(--green)"></span>
      <span class="dd-term-title">data-dash — phaser — 800×500</span>
    </div>
    <div class="dd-term-body">
      <div id="game-container"></div>
    </div>
  </div>

  <!-- Controls hint -->
  <div class="dd-controls">
    <span class="dd-key">← → / A D</span> <span class="dd-ctrl-label">Move</span>
    <span class="dd-ctrl-sep">·</span>
    <span class="dd-key">↑ / W / Space</span> <span class="dd-ctrl-label">Jump</span>
    <span class="dd-ctrl-sep">·</span>
    <span class="dd-key">Z / X</span> <span class="dd-ctrl-label">Fire Paper</span>
    <span class="dd-ctrl-sep">·</span>
    <span class="dd-key">ESC</span> <span class="dd-ctrl-label">Pause</span>
  </div>

  <!-- Mobile touch controls — overlay on game in landscape -->
  <div class="dd-touch-controls" aria-label="Touch controls">
    <div class="dd-touch-dpad">
      <button class="dd-touch-btn dd-touch-left" aria-label="Move left">&#9664;</button>
      <button class="dd-touch-btn dd-touch-right" aria-label="Move right">&#9654;</button>
    </div>
    <div class="dd-touch-actions">
      <button class="dd-touch-btn dd-touch-jump" aria-label="Jump">&#9650;</button>
      <button class="dd-touch-btn dd-touch-fire" aria-label="Fire">&#9679;</button>
    </div>
  </div>

  <!-- Mobile notice -->
  <div class="dd-mobile-notice">
    <p>Data Dash is best experienced on desktop with a keyboard.</p>
  </div>

  <!-- Rotate prompt (portrait on small screens) -->
  <div class="dd-rotate-prompt" aria-label="Rotate device">
    <div class="dd-rotate-icon">&#x21BB;</div>
    <p>Rotate your phone to landscape to play</p>
  </div>
</section>
</main>

<script>
  import { createGame } from '../game/index';

  const container = document.getElementById('game-container');
  if (container) {
    if (document.readyState === 'complete') {
      createGame('game-container');
    } else {
      window.addEventListener('load', () => createGame('game-container'));
    }
  }

  // Touch controls — emit synthetic keyboard events
  const touchMap: Record<string, string> = {
    'dd-touch-left': 'ArrowLeft',
    'dd-touch-right': 'ArrowRight',
    'dd-touch-jump': 'ArrowUp',
    'dd-touch-fire': 'z',
  };
  document.querySelectorAll('.dd-touch-btn').forEach(btn => {
    const cls = [...btn.classList].find(c => c.startsWith('dd-touch-') && c !== 'dd-touch-btn');
    if (!cls) return;
    const key = touchMap[cls];
    if (!key) return;
    const opts = { key, code: key.length === 1 ? `Key${key.toUpperCase()}` : key, bubbles: true };
    btn.addEventListener('touchstart', e => {
      e.preventDefault();
      document.dispatchEvent(new KeyboardEvent('keydown', opts));
    }, { passive: false });
    btn.addEventListener('touchend', e => {
      e.preventDefault();
      document.dispatchEvent(new KeyboardEvent('keyup', opts));
    }, { passive: false });
  });

  // Bouncing Minties — frictionless vacuum physics
  const squids = document.querySelectorAll<HTMLImageElement>('.dd-float-squid');
  interface Ball { el: HTMLImageElement; x: number; y: number; vx: number; vy: number; r: number; rot: number; vr: number; }
  const balls: Ball[] = [];

  squids.forEach((squid) => {
    squid.style.transition = 'none';
    const size = squid.offsetWidth || 80;
    const r = size / 2;
    const speed = 30 + Math.random() * 50;
    const angle = Math.random() * Math.PI * 2;
    const b: Ball = {
      el: squid, r,
      x: r + Math.random() * (window.innerWidth - size),
      y: r + Math.random() * (window.innerHeight - size),
      vx: Math.cos(angle) * speed,
      vy: Math.sin(angle) * speed,
      rot: Math.random() * 360,
      vr: (Math.random() - 0.5) * 20,
    };
    b.el.style.left = `${b.x - b.r}px`;
    b.el.style.top = `${b.y - b.r}px`;
    b.el.style.transform = `rotate(${b.rot}deg)`;
    balls.push(b);
  });

  let last = performance.now();
  function tick(now: number) {
    const dt = Math.min((now - last) / 1000, 0.05);
    last = now;
    const W = window.innerWidth;
    const H = window.innerHeight;

    // Move
    for (const b of balls) {
      b.x += b.vx * dt;
      b.y += b.vy * dt;
      b.rot += b.vr * dt;

      // Wall bounce
      if (b.x - b.r < 0) { b.x = b.r; b.vx = Math.abs(b.vx); b.vr += (Math.random() - 0.5) * 10; }
      if (b.x + b.r > W) { b.x = W - b.r; b.vx = -Math.abs(b.vx); b.vr += (Math.random() - 0.5) * 10; }
      if (b.y - b.r < 0) { b.y = b.r; b.vy = Math.abs(b.vy); b.vr += (Math.random() - 0.5) * 10; }
      if (b.y + b.r > H) { b.y = H - b.r; b.vy = -Math.abs(b.vy); b.vr += (Math.random() - 0.5) * 10; }
    }

    // Collisions (elastic, equal mass)
    for (let i = 0; i < balls.length; i++) {
      for (let j = i + 1; j < balls.length; j++) {
        const a = balls[i], c = balls[j];
        const dx = c.x - a.x, dy = c.y - a.y;
        const dist = Math.hypot(dx, dy);
        const minD = a.r + c.r;
        if (dist < minD && dist > 0) {
          // Separate
          const nx = dx / dist, ny = dy / dist;
          const overlap = (minD - dist) / 2;
          a.x -= nx * overlap; a.y -= ny * overlap;
          c.x += nx * overlap; c.y += ny * overlap;
          // Swap velocity components along collision normal
          const dvx = a.vx - c.vx, dvy = a.vy - c.vy;
          const dot = dvx * nx + dvy * ny;
          if (dot > 0) {
            a.vx -= dot * nx; a.vy -= dot * ny;
            c.vx += dot * nx; c.vy += dot * ny;
            // Spin transfer
            a.vr += (Math.random() - 0.5) * 15;
            c.vr -= (Math.random() - 0.5) * 15;
            // Accelerate on collision — compounds ~2.7× after 100 collisions
            const boost = 1.01;
            a.vx *= boost; a.vy *= boost;
            c.vx *= boost; c.vy *= boost;
          }
        }
      }
    }

    // Render
    for (const b of balls) {
      b.el.style.left = `${b.x - b.r}px`;
      b.el.style.top = `${b.y - b.r}px`;
      b.el.style.transform = `rotate(${b.rot}deg)`;
    }

    requestAnimationFrame(tick);
  }
  requestAnimationFrame(tick);
</script>

<style>
  .data-dash-page {
    position: relative;
    padding: 40px 24px 60px;
    max-width: 960px;
    margin: 0 auto;
    min-height: 100vh;
  }

  /* ---- Floating Minties ---- */
  .dd-floating-minties {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .dd-float-squid {
    position: absolute;
    opacity: 0.18;
    filter: drop-shadow(0 0 20px rgba(46, 196, 182, 0.3));
    will-change: left, top, transform;
  }

  /* ---- Hero ---- */
  .dd-hero {
    text-align: center;
    margin-bottom: 24px;
    position: relative;
    z-index: 1;
  }

  .dd-hero h1 {
    font-size: 28px;
    color: var(--accent);
    min-height: 1.3em;
  }

  .dd-sub {
    color: var(--text-2);
    font-size: 12px;
    margin-top: 8px;
    min-height: 1.7em;
  }

  /* ---- Terminal Game Window ---- */
  .dd-terminal {
    border: 1px dashed var(--accent-dim);
    background: var(--bg-0);
    overflow: hidden;
    position: relative;
    z-index: 1;
    max-width: 832px;
    margin: 0 auto;
  }

  .dd-term-titlebar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    background: var(--bg-2);
    border-bottom: 1px dashed var(--border);
  }

  .dd-term-title {
    margin-left: auto;
    font-size: 9px;
    color: var(--text-3);
  }

  .dd-term-body {
    padding: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 500px;
    background: #0a0a0a;
  }

  #game-container {
    max-width: 800px;
    width: 100%;
    aspect-ratio: 8 / 5;
    touch-action: none;
  }

  #game-container canvas {
    display: block;
    image-rendering: pixelated;
  }

  /* ---- Controls ---- */
  .dd-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 16px;
    font-size: 11px;
    color: var(--text-3);
    position: relative;
    z-index: 1;
  }

  .dd-key {
    background: var(--bg-3);
    padding: 2px 6px;
    border: 1px solid var(--border);
    color: var(--text-2);
    font-size: 10px;
  }

  .dd-ctrl-label {
    color: var(--text-3);
  }

  .dd-ctrl-sep {
    color: var(--text-3);
    opacity: 0.5;
  }

  /* ---- Touch controls ---- */
  .dd-touch-controls {
    display: none;
    position: relative;
    z-index: 10;
  }

  .dd-touch-dpad,
  .dd-touch-actions {
    display: flex;
    gap: 8px;
  }

  .dd-touch-btn {
    width: 56px;
    height: 56px;
    border: 1px solid var(--accent-dim);
    border-radius: 12px;
    background: rgba(17, 17, 17, 0.75);
    color: var(--text-2);
    font-size: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    touch-action: none;
    user-select: none;
    -webkit-user-select: none;
    cursor: pointer;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .dd-touch-btn:active {
    background: rgba(46, 196, 182, 0.3);
    color: var(--accent);
    border-color: var(--accent);
  }

  .dd-touch-fire {
    border-color: var(--accent);
  }

  /* ---- Mobile notice ---- */
  .dd-mobile-notice {
    display: none;
    text-align: center;
    margin-top: 24px;
    padding: 12px;
    border: 1px dashed var(--accent-dim);
    color: var(--text-2);
    font-size: 11px;
    position: relative;
    z-index: 1;
  }

  /* ---- Rotate prompt ---- */
  .dd-rotate-prompt {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: var(--bg-0, #0a0a0a);
    color: var(--text-2, #abb2bf);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    font-size: 14px;
    text-align: center;
    padding: 24px;
  }

  .dd-rotate-icon {
    font-size: 48px;
    color: var(--accent, #2ec4b6);
    animation: dd-rotate-nudge 2s ease-in-out infinite;
  }

  @keyframes dd-rotate-nudge {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(90deg); }
    75% { transform: rotate(90deg); }
  }

  /* ---- Mobile: narrow screens ---- */
  @media (max-width: 860px) {
    .dd-mobile-notice { display: block; }
    .dd-controls { display: none; }
    .dd-float-squid { display: none; }
  }

  /* ---- Mobile portrait: show rotate prompt ---- */
  @media (max-width: 600px) and (orientation: portrait) {
    .dd-rotate-prompt { display: flex; }
    .dd-terminal { display: none; }
    .dd-touch-controls { display: none !important; }
    .dd-mobile-notice { display: none; }
  }

  /* ---- Mobile landscape: fullscreen game + overlay controls ---- */
  @media (max-height: 500px) and (orientation: landscape) {
    .data-dash-page {
      padding: 0;
      max-width: none;
    }

    .dd-hero { display: none; }
    .dd-mobile-notice { display: none; }
    .dd-controls { display: none; }
    .dd-float-squid { display: none; }

    .dd-terminal {
      border: none;
      max-width: none;
    }

    .dd-term-titlebar { display: none; }

    .dd-term-body {
      min-height: 100vh;
      min-height: 100dvh;
    }

    #game-container {
      max-width: none;
      width: 100%;
      height: 100vh;
      height: 100dvh;
      aspect-ratio: auto;
    }

    .dd-touch-controls {
      display: flex;
      position: fixed;
      bottom: 12px;
      left: 12px;
      right: 12px;
      justify-content: space-between;
      align-items: flex-end;
      z-index: 100;
      pointer-events: none;
    }

    .dd-touch-dpad,
    .dd-touch-actions {
      pointer-events: auto;
    }

    .dd-touch-btn {
      width: 52px;
      height: 52px;
      font-size: 20px;
      opacity: 0.7;
    }

    .dd-touch-btn:active {
      opacity: 1;
    }
  }
</style>

</BaseLayout>
