---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="MINT Lab — Corpus Map">

<main>

<section class="hero" id="corpus-map-hero" style="padding-bottom: 24px;">
  <img src={`${base}/assets/wireframe-squid.png`} alt="" class="watermark" />
  <h1 data-typing="❯ ./corpus-map --interactive"><span class="typing-cursor"></span></h1>
  <p class="subtitle">Interactive visualization of the MINT Lab research corpus &mdash; updated daily</p>
</section>

<section class="no-brackets" style="padding: 0 0 48px; max-width: none;">
  <div class="map-container">
    <iframe
      src={`${base}/paper-map/`}
      title="MINT Lab Research Corpus Map"
      class="map-frame"
      loading="lazy"
    ></iframe>
  </div>
</section>

</main>

</BaseLayout>

<style>
  .map-container {
    width: calc(100% + var(--sidebar-w));
    margin-left: calc(-1 * var(--sidebar-w));
    height: calc(100vh - 200px);
    min-height: 500px;
    position: relative;
    border-top: 1px dashed rgba(46, 196, 182, 0.15);
    border-bottom: 1px dashed rgba(46, 196, 182, 0.15);
  }
  .map-frame {
    width: 100%;
    height: 100%;
    border: none;
    background: #080d14;
  }
  @media (max-width: 768px) {
    .map-container {
      width: 100%;
      margin-left: 0;
      height: calc(100vh - 160px);
    }
  }
</style>
