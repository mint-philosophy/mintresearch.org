function openSearch() {
  document.getElementById('searchOverlay').classList.add('open');
  document.getElementById('searchInput').value = '';
  document.getElementById('searchInput').focus();
  doSearch('');
}
function closeSearch() {
  document.getElementById('searchOverlay').classList.remove('open');
}

function doSearch(q) {
  const res = document.getElementById('searchResults');
  const query = q.toLowerCase().trim();
  const items = query ? searchData.filter(s => s.t.toLowerCase().includes(query) || s.d.toLowerCase().includes(query)) : searchData.slice(0, 12);
  res.innerHTML = items.map(s => `
    <div class="sr-item" onclick="location.href='${s.s}';closeSearch();">
      <span class="sr-tag" style="background:${s.c}22;color:${s.c}">${s.tag}</span>
      <span class="sr-title">${s.t}</span>
      <div class="sr-desc">${s.d}</div>
    </div>
  `).join('') || '<div style="padding:20px;text-align:center;color:var(--text-3)">No results</div>';
}

// Search trigger
document.getElementById('searchTrigger').addEventListener('click', openSearch);

// Search input handler
document.getElementById('searchInput').addEventListener('input', function() { doSearch(this.value); });

// Search overlay dismiss
document.getElementById('searchOverlay').addEventListener('click', function(e) { if (e.target === this) closeSearch(); });

// Ctrl/Cmd+K
document.addEventListener('keydown', e => {
  if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); openSearch(); }
  if (e.key === 'Escape') closeSearch();
});

// ===== 41Q cell click to expand =====
document.querySelectorAll('.q-cell').forEach(function(cell) {
  cell.addEventListener('click', function() {
    this.classList.toggle('expanded');
  });
});

// ===== Prompt item tap to expand (mobile) =====
document.querySelectorAll('.prompt-item').forEach(function(item) {
  item.addEventListener('click', function() {
    var wasExpanded = this.classList.contains('expanded');
    document.querySelectorAll('.prompt-item.expanded').forEach(function(el) { el.classList.remove('expanded'); });
    if (!wasExpanded) this.classList.add('expanded');
  });
});

// ===== Scroll spy =====
const navLinks = document.querySelectorAll('.nav-link');
const sections = document.querySelectorAll('section[id]');
window.addEventListener('scroll', () => {
  let current = '';
  sections.forEach(s => { if (window.scrollY >= s.offsetTop - 100) current = s.id; });
  navLinks.forEach(l => {
    l.classList.remove('active');
    if (l.getAttribute('href') === '#' + current) l.classList.add('active');
  });
});

// ===== Fade in on scroll =====
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.1 });
document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

