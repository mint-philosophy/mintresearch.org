<script is:inline>
// ===== Shared tooltip positioning helper =====
function clampTip(tip, anchorRect, containerSel) {
  var pad = 10;
  var tw = tip.offsetWidth || 300;
  var th = tip.offsetHeight || 80;
  var vw = window.innerWidth;
  var vh = window.innerHeight;
  // Get container bounds (diagram or section) to avoid going outside it
  var container = anchorRect._container;
  if (!container && containerSel) {
    var el = document.querySelector(containerSel);
    if (el) container = el.getBoundingClientRect();
  }
  var minX = container ? Math.max(pad, container.left) : pad;
  var maxX = container ? Math.min(vw - pad, container.right) : vw - pad;
  // Position below the anchor, centered horizontally
  var x = anchorRect.left + (anchorRect.width / 2) - (tw / 2);
  var y = anchorRect.bottom + 8;
  // Clamp horizontal: stay within container/viewport
  if (x + tw > maxX) x = maxX - tw;
  if (x < minX) x = minX;
  // If it goes below viewport, flip above
  if (y + th > vh) y = anchorRect.top - th - 8;
  if (y < pad) y = pad;
  tip.style.left = x + 'px';
  tip.style.top = y + 'px';
}

// ===== Make a tooltip draggable on touch =====
function makeDraggable(tip) {
  var dragging = false, startX, startY, origX, origY;
  tip.addEventListener('touchstart', function(e) {
    if (e.touches.length !== 1) return;
    dragging = true;
    startX = e.touches[0].clientX;
    startY = e.touches[0].clientY;
    origX = parseInt(tip.style.left) || 0;
    origY = parseInt(tip.style.top) || 0;
    tip.style.transition = 'none';
    e.preventDefault();
  }, {passive: false});
  tip.addEventListener('touchmove', function(e) {
    if (!dragging) return;
    var dx = e.touches[0].clientX - startX;
    var dy = e.touches[0].clientY - startY;
    tip.style.left = (origX + dx) + 'px';
    tip.style.top = (origY + dy) + 'px';
    e.preventDefault();
  }, {passive: false});
  tip.addEventListener('touchend', function() {
    dragging = false;
    tip.style.transition = '';
  });
}

// ===== Pipeline tooltips =====
(function() {
  var tip = document.getElementById('pipelineTip');
  if (!tip) return;
  var isTouch = 'ontouchstart' in window;
  var activeNode = null;
  var pipeWrap = document.querySelector('.pipeline-wrap');
  makeDraggable(tip);

  document.querySelectorAll('.pn').forEach(function(node) {
    if (!isTouch) {
      node.addEventListener('mouseenter', function(e) {
        var text = this.getAttribute('data-tip');
        if (!text) return;
        tip.textContent = text;
        var rect = this.querySelector('rect');
        var col = rect ? rect.getAttribute('stroke') : null;
        tip.style.borderColor = (col && col !== 'rgba(255,255,255,0.1)') ? col : 'var(--mint)';
        tip.classList.add('visible');
      });
      node.addEventListener('mousemove', function(e) {
        var x = e.clientX + 14;
        var y = e.clientY + 14;
        var vw = window.innerWidth;
        var pw = pipeWrap ? pipeWrap.getBoundingClientRect() : null;
        var maxR = pw ? pw.right : vw;
        var minL = pw ? pw.left : 0;
        if (x + 330 > maxR) x = maxR - 330;
        if (x < minL) x = minL;
        if (y + 100 > window.innerHeight) y = e.clientY - 80;
        tip.style.left = x + 'px';
        tip.style.top = y + 'px';
      });
      node.addEventListener('mouseleave', function() {
        tip.classList.remove('visible');
      });
    }

    // Touch: tap to toggle
    if (isTouch) {
      node.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        if (activeNode === this && tip.classList.contains('visible')) {
          tip.classList.remove('visible');
          activeNode = null;
          return;
        }
        var text = this.getAttribute('data-tip');
        if (!text) return;
        tip.textContent = text;
        var rect = this.querySelector('rect');
        var col = rect ? rect.getAttribute('stroke') : null;
        tip.style.borderColor = (col && col !== 'rgba(255,255,255,0.1)') ? col : 'var(--mint)';
        // Position clamped to pipeline diagram bounds
        var svgEl = this.closest('svg');
        var svgRect = svgEl ? svgEl.getBoundingClientRect() : null;
        var nodeRect = this.getBoundingClientRect();
        var ar = {left: nodeRect.left, right: nodeRect.right, top: nodeRect.top, bottom: nodeRect.bottom, width: nodeRect.width, height: nodeRect.height};
        ar._container = svgRect;
        tip.classList.add('visible');
        // Need to measure after visible so offsetWidth/Height are real
        requestAnimationFrame(function() { clampTip(tip, ar); });
        activeNode = this;
      });
    }
  });

  if (isTouch) {
    document.addEventListener('click', function(e) {
      if (activeNode && !activeNode.contains(e.target) && !tip.contains(e.target)) {
        tip.classList.remove('visible');
        activeNode = null;
      }
    });
  }
})();

// ===== Hover/tap tooltips (ingest stages, corpus search cards, etc.) =====
// Simplified: single global click handler, no IIFE scope issues.
(function() {
  var tip = document.getElementById('ingestTip');
  if (!tip) return;
  makeDraggable(tip);
  var activeEl = null;

  // Desktop hover (non-touch only)
  if (!('ontouchstart' in window)) {
    document.querySelectorAll('[data-ingest-tip]').forEach(function(el) {
      el.addEventListener('mouseenter', function() {
        tip.innerHTML = this.getAttribute('data-ingest-tip');
        tip.style.borderColor = this.getAttribute('data-ingest-color') || 'var(--mint)';
        tip.classList.add('visible');
        activeEl = this;
      });
      el.addEventListener('mousemove', function(e) {
        var x = e.clientX + 14, y = e.clientY + 14;
        if (x + 350 > window.innerWidth) x = window.innerWidth - 360;
        if (x < 10) x = 10;
        if (y + 100 > window.innerHeight) y = e.clientY - 80;
        tip.style.left = x + 'px';
        tip.style.top = y + 'px';
      });
      el.addEventListener('mouseleave', function() {
        tip.classList.remove('visible');
        activeEl = null;
      });
    });
  }

  // Universal click handler — works on both touch AND mouse as fallback.
  document.addEventListener('click', function(e) {
    // Ignore clicks on the tip itself (for dragging)
    if (tip.contains(e.target)) return;

    var target = e.target.closest('[data-ingest-tip]');

    // Clicked outside any tooltip target — dismiss
    if (!target) {
      if (activeEl) { tip.classList.remove('visible'); activeEl = null; }
      return;
    }

    // Clicked the same target — toggle off
    if (activeEl === target && tip.classList.contains('visible')) {
      tip.classList.remove('visible');
      activeEl = null;
      return;
    }

    // Show tooltip
    tip.innerHTML = target.getAttribute('data-ingest-tip');
    tip.style.borderColor = target.getAttribute('data-ingest-color') || 'var(--mint)';
    var r = target.getBoundingClientRect();
    var sec = target.closest('section');
    var ar = {left:r.left, right:r.right, top:r.top, bottom:r.bottom, width:r.width, height:r.height};
    ar._container = sec ? sec.getBoundingClientRect() : null;
    tip.classList.add('visible');
    requestAnimationFrame(function() { clampTip(tip, ar); });
    activeEl = target;
  }, true);  // useCapture=true — fires BEFORE any other click handlers
})();

// Mobile menu is handled by BaseLayout.astro — no duplicate listeners here.

// Card toggle is handled by BaseLayout.astro (line 155-158) which attaches
// click listeners to all .card .card-head elements. No duplicate here.

// ===== Accordion toggle =====
function toggleAcc(el) {
  el.classList.toggle('open');
}

// ===== Tabs =====
function switchTab(e, id) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
  e.target.classList.add('active');
  document.getElementById(id).classList.add('active');
}

