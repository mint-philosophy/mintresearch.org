      <div class="card-head">
        <div class="card-icon" style="background:rgba(136,146,166,0.08);color:#8892a6">&#128203;</div>
        <div><div class="card-title">List Previous</div><div class="card-sub">Instant</div></div>
      </div>
    </div>
    <div class="card" style="border-color:var(--pink)" data-ingest-tip="Search recent news from #mint-community and #firehose via a dedicated ChromaDB news index (refreshed hourly). Returns recent items matching your query, ranked by relevance and recency." data-ingest-color="#f472b6">
