<!-- ============ @MINTY: CORPUS SEARCH ============ -->
<Section id="corpus-search" num="05">
  <h2 class="cli-call" data-section-name="Corpus Search"><span class="section-label">Corpus Search</span><span class="cli-line"><span class="fn">Grep</span><span class="op">(</span><span class="kw">pattern</span><span class="op">=</span><span class="str">"your question"</span><span class="op">,</span> <span class="kw">path</span><span class="op">=</span><span class="str">"corpus/"</span><span class="op">)</span><span class="cli-cursor"></span></span></h2>
  <p class="lead">Mention <code>@Minty</code> in <code>#mint-community</code> with a research question to get an interactive menu of search modes.</p>

  <div class="cards" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr))">
    <div class="card" style="border-color:var(--cyan)" data-ingest-tip="Semantic query expansion across 48 embedding dimensions with Reciprocal Rank Fusion. Returns ranked papers with relevance snippets. Uses a warm search server with pre-loaded 4GB LanceDB table for sub-second retrieval." data-ingest-color="#22d3ee">
      <div class="card-head">
        <div class="card-icon" style="background:rgba(34,211,238,0.08);color:#22d3ee">&#9889;</div>
        <div><div class="card-title">Fast Search</div><div class="card-sub">~2 min</div></div>
      </div>
    </div>
    <div class="card" style="border-color:var(--indigo)" data-ingest-tip="Short literature review — search + synthesis in one pass. Good for getting a quick overview of a topic with citations. Runs a single search round followed by an Opus synthesis pass." data-ingest-color="#818cf8">
      <div class="card-head">
        <div class="card-icon" style="background:rgba(129,140,248,0.08);color:#818cf8">&#128214;</div>
        <div><div class="card-title">Fast Review</div><div class="card-sub">~15 min</div></div>
      </div>
    </div>
    <div class="card" style="border-color:var(--mint);border-width:2px" data-ingest-tip="Full 4-phase pipeline: multi-round search (Opus, up to 2 gap-analysis rounds), parallel paper reading (Codex GPT-5.2, up to 6 concurrent readers split into top-tier and summary-tier), synthesis (Opus, 3,000&ndash;5,000 word report), and QA verification (Opus, cross-reference + citation fix). Result posted as a Slack canvas." data-ingest-color="#2ec4b6">
      <div class="card-head">
        <div class="card-icon" style="background:rgba(46,196,182,0.12);color:#2ec4b6">&#9733;</div>
        <div><div class="card-title">Deep Review</div><div class="card-sub">~60 min &middot; Primary</div></div>
      </div>
    </div>
    <div class="card" style="border-color:#8892a6" data-ingest-tip="Direct Q&amp;A with full tool access to the corpus — good for quick factual questions. The agent can search, read papers, and reason across them in a multi-turn conversation." data-ingest-color="#8892a6">
      <div class="card-head">
        <div class="card-icon" style="background:rgba(136,146,166,0.08);color:#8892a6">&#128172;</div>
        <div><div class="card-title">Conversation</div><div class="card-sub">Instant</div></div>
      </div>
    </div>
