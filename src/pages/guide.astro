// ===== Newsletter subscribe =====
document.getElementById('subscribe-form').addEventListener('submit', function(e) {
  e.preventDefault();
  const msg = document.getElementById('subscribe-msg');
  const btn = this.querySelector('button');
  const email = this.querySelector('input[name="email"]').value;
  const website = this.querySelector('input[name="website"]').value;
  btn.disabled = true;
  btn.textContent = 'Subscribing...';
  msg.textContent = '';
  msg.style.color = 'var(--text-2)';
  fetch('https://api.mintresearch.org/api/subscribe', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({email: email, website: website})
  })
  .then(function(r) { return r.json().then(function(d) { return {ok: r.ok, data: d}; }); })
  .then(function(res) {
    if (res.ok) {
      msg.style.color = 'var(--green)';
      msg.textContent = res.data.message === 'already subscribed' ? 'You\'re already subscribed!' : 'Subscribed! You\'ll get the next issue.';
      btn.textContent = 'Subscribed';
    } else {
      throw new Error(res.data.error || 'Something went wrong');
    }
  })
  .catch(function(err) {
    msg.style.color = 'var(--red)';
    msg.textContent = err.message || 'Failed to subscribe. Try again.';
    btn.disabled = false;
    btn.textContent = 'Subscribe';
  });
});

// ===== Cluster viz lazy-load =====
(function() {
  var vizFrame = document.getElementById('cluster-viz');
  var vizPlaceholder = document.getElementById('cluster-viz-placeholder');
  if (!vizFrame) return;
  var loaded = false;
  var vizObserver = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting && !loaded) {
        loaded = true;
        vizFrame.src = '/mintresearch.org/paper-map/?embed=true';
        vizFrame.onload = function() {
          vizFrame.style.opacity = '1';
          vizPlaceholder.style.display = 'none';
        };
        vizObserver.disconnect();
      }
    });
  }, { threshold: 0.1 });
  vizObserver.observe(vizFrame.parentElement);
})();

