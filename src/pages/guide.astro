---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import RefTable from '../components/RefTable.astro';
---

<BaseLayout title="Agentic Research Infrastructure for AI Alignment, Governance and Adaptation">

<main>

<!-- ============ HERO ============ -->
<section class="hero" id="overview">
  <img src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/assets/wireframe-squid.png`} alt="" class="watermark" />
  <h1 data-typing="❯ Agentic Research Infrastructure for AI Alignment, Governance and Adaptation"><span class="typing-cursor"></span></h1>
</section>

<!-- ============ PIPELINE ============ -->
<section id="pipeline" class="fade-in no-brackets">

  <div class="pipeline-wrap">
    <svg viewBox="0 0 960 710" width="100%" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" style="font-family:'JetBrains Mono',monospace" data-anim-delayed>
      <defs>
        <marker id="arrowBlue" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto"><path d="M0,0 L8,3 L0,6" fill="#22d3ee"/></marker>
        <marker id="arrowGreen" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto"><path d="M0,0 L8,3 L0,6" fill="#2ec4b6"/></marker>
        <marker id="arrowOrange" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto"><path d="M0,0 L8,3 L0,6" fill="#f59e0b"/></marker>
        <marker id="arrowPurple" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto"><path d="M0,0 L8,3 L0,6" fill="#a78bfa"/></marker>
        <marker id="arrowTeal" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto"><path d="M0,0 L8,3 L0,6" fill="#2dd4bf"/></marker>
        <marker id="arrowPink" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto"><path d="M0,0 L8,3 L0,6" fill="#f472b6"/></marker>
        <linearGradient id="nodeGrad" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#1a1f2c"/><stop offset="100%" stop-color="#13171f"/></linearGradient>
        <filter id="glow"><feGaussianBlur stdDeviation="3" result="blur"/><feFlood flood-color="#2ec4b6" flood-opacity="0.3" result="color"/><feComposite in="color" in2="blur" operator="in" result="colorBlur"/><feMerge><feMergeNode in="colorBlur"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
      </defs>

      <!-- ===== ROW 0: Horizontal input chain ===== -->
      <g class="pn" data-tip="Six input sources: Twitter/X, arXiv preprints, RSS feeds, Substack newsletters, Bluesky, and email newsletters. Hundreds of new items appear daily." style="cursor:pointer" transform="translate(20,15)">
        <rect width="135" height="48" fill="url(#nodeGrad)" stroke="rgba(255,255,255,0.1)"/>
        <text x="68" y="18" text-anchor="middle" fill="#94a3b8" font-size="9" font-weight="600">EXTERNAL SOURCES</text>
        <text x="68" y="32" text-anchor="middle" fill="#e2e8f0" font-size="9">Twitter, arXiv, RSS, Substack</text>
        <text x="68" y="43" text-anchor="middle" fill="#e2e8f0" font-size="9">Bluesky, Email</text>
      </g>
      <line x1="155" y1="39" x2="175" y2="39" stroke="#22d3ee" stroke-width="1.5" marker-end="url(#arrowBlue)"/>

      <g class="pn" data-tip="Scheduled daemon that fetches from all sources, deduplicates against a 400-item cache, then scores each item with Claude Opus across six weighted dimensions — Relevance (.30), Quality (.25), Authority (.15), Novelty (.15), Actionability (.10), Engagement (.05) — against a ~2,200-word research interest profile covering AI safety, governance, agent engineering, political economy, and more. Items above the composite threshold are ranked and posted to Slack." style="cursor:pointer" transform="translate(183,18)">
        <rect width="120" height="42" fill="url(#nodeGrad)" stroke="#22d3ee" stroke-width="1.5"/>
        <text x="60" y="18" text-anchor="middle" fill="#22d3ee" font-size="10" font-weight="700">feedme-daily</text>
        <text x="60" y="32" text-anchor="middle" fill="#94a3b8" font-size="8">Fetch, Classify, Rank</text>
      </g>
      <line x1="303" y1="39" x2="323" y2="39" stroke="#22d3ee" stroke-width="1.5" marker-end="url(#arrowBlue)"/>

      <g class="pn" data-tip="Daily Slack channels (#feed-monday, #feed-tuesday, etc.) where classified items land. Seth reviews these and thumbs-up the ones worth promoting." style="cursor:pointer" transform="translate(331,18)">
        <rect width="95" height="42" fill="#0f1520" stroke="rgba(255,255,255,0.1)"/>
        <text x="48" y="18" text-anchor="middle" fill="#fbbf24" font-size="10" font-weight="700">#feed-{'{'}day{'}'}</text>
        <text x="48" y="32" text-anchor="middle" fill="#94a3b8" font-size="8">Slack channel</text>
      </g>
      <line x1="426" y1="39" x2="446" y2="39" stroke="#fbbf24" stroke-width="1" stroke-dasharray="3,3"/>

      <g class="pn" data-tip="Human-in-the-loop curation. Seth reviews classified items and reacts with thumbs-up to promote them through the pipeline. This is the only manual step." style="cursor:pointer" transform="translate(449,22)">
        <rect width="80" height="34" fill="url(#nodeGrad)" stroke="#fbbf24" stroke-dasharray="4,3"/>
        <text x="40" y="22" text-anchor="middle" fill="#fbbf24" font-size="10">Seth &#x1F44D;</text>
      </g>
      <line x1="529" y1="39" x2="549" y2="39" stroke="#2ec4b6" stroke-width="1.5" marker-end="url(#arrowGreen)"/>

      <g class="pn" data-tip="Watches #feed channels for Seth's thumbs-up reactions every 5 minutes. Copies promoted messages verbatim to #firehose, including validated PDF attachments from thread replies." style="cursor:pointer" transform="translate(557,18)">
        <rect width="120" height="42" fill="url(#nodeGrad)" stroke="#2ec4b6" stroke-width="1.5"/>
        <text x="60" y="18" text-anchor="middle" fill="#2ec4b6" font-size="10" font-weight="700">feed-promote</text>
        <text x="60" y="32" text-anchor="middle" fill="#94a3b8" font-size="8">Copy to #firehose</text>
      </g>

      <!-- feed-promote arrow DOWN to hub -->
      <line x1="617" y1="60" x2="617" y2="85" stroke="#2ec4b6" stroke-width="1.5"/>
      <line x1="617" y1="85" x2="510" y2="85" stroke="#2ec4b6" stroke-width="1.5"/>
      <line x1="510" y1="85" x2="510" y2="105" stroke="#2ec4b6" stroke-width="1.5" marker-end="url(#arrowGreen)"/>

      <!-- ===== ROW 1: Two writers -> #firehose hub ===== -->
      <g class="pn" data-tip="Direct sharing from any device — iPhone share sheet, Mac hotkey (Cmd+Shift+M), Chrome extension, or manual paste. Bypasses automated classification with a score override of 1.0." style="cursor:pointer" transform="translate(30,108)">
        <rect width="140" height="42" fill="url(#nodeGrad)" stroke="#fbbf24" stroke-dasharray="4,3"/>
        <text x="70" y="17" text-anchor="middle" fill="#fbbf24" font-size="9" font-weight="600">SETH'S DEVICES</text>
        <text x="70" y="32" text-anchor="middle" fill="#e2e8f0" font-size="9">iPhone, Mac, Chrome</text>
      </g>
      <line x1="170" y1="129" x2="195" y2="129" stroke="#f59e0b" stroke-width="1.5" marker-end="url(#arrowOrange)"/>

      <g class="pn" data-tip="Real-time intake daemon via Slack Socket Mode. When Seth shares a URL from any device, it immediately classifies, enriches with metadata and PDFs, and posts to #firehose." style="cursor:pointer" transform="translate(203,108)">
        <rect width="130" height="42" fill="url(#nodeGrad)" stroke="#f59e0b" stroke-width="1.5"/>
        <text x="65" y="17" text-anchor="middle" fill="#f59e0b" font-size="10" font-weight="700">share-to-minty</text>
        <text x="65" y="32" text-anchor="middle" fill="#94a3b8" font-size="8">Classify &amp; post to #firehose</text>
      </g>
      <line x1="333" y1="129" x2="440" y2="129" stroke="#f59e0b" stroke-width="1.5" marker-end="url(#arrowOrange)"/>

      <!-- #firehose central hub -->
      <g class="pn" data-tip="The central hub channel. All curated content converges here — both automated (via feed-promote) and manual (via share-to-minty). Three downstream daemons read from this channel." style="cursor:pointer" transform="translate(440,105)">
        <rect width="140" height="65" fill="#0f1520" stroke="#22d3ee" stroke-width="2" filter="url(#glow)"/>
        <text x="70" y="25" text-anchor="middle" fill="#22d3ee" font-size="13" font-weight="800">#firehose</text>
        <text x="70" y="42" text-anchor="middle" fill="#94a3b8" font-size="9">Automated Hub</text>
        <text x="70" y="55" text-anchor="middle" fill="#64748b" font-size="9">2 writers / 3 readers</text>
      </g>

      <!-- ===== RIGHT COLUMN: Digest loop ===== -->
      <line x1="580" y1="130" x2="640" y2="130" stroke="#f472b6" stroke-width="1.5" marker-end="url(#arrowPink)"/>

      <g class="pn" data-tip="Generates a narrative daily digest from the previous day's #firehose posts using Claude. Sends as a rich HTML email to 29 lab members across 11 institutions and posts to #mint-community." style="cursor:pointer" transform="translate(648,108)">
        <rect width="150" height="50" fill="url(#nodeGrad)" stroke="#f472b6" stroke-width="1.5"/>
        <text x="75" y="19" text-anchor="middle" fill="#f472b6" font-size="10" font-weight="700">yesterday-in-ai</text>
        <text x="75" y="33" text-anchor="middle" fill="#94a3b8" font-size="8">Daily/weekly digest</text>
        <text x="75" y="44" text-anchor="middle" fill="#64748b" font-size="8">#mint-community + email</text>
      </g>

      <line x1="798" y1="133" x2="838" y2="133" stroke="#f472b6" stroke-width="1" marker-end="url(#arrowPink)"/>
      <g class="pn" data-tip="Rich HTML email digest sent daily to 29 lab members across 11 institutions, including MINT Lab members, collaborators at Stanford, ANU, and elsewhere." style="cursor:pointer" transform="translate(846,114)">
        <rect width="100" height="38" fill="url(#nodeGrad)" stroke="rgba(255,255,255,0.1)"/>
        <text x="50" y="16" text-anchor="middle" fill="#f472b6" font-size="9" font-weight="600">Email</text>
        <text x="50" y="30" text-anchor="middle" fill="#64748b" font-size="8">29 lab members</text>
      </g>

      <line x1="723" y1="158" x2="723" y2="200" stroke="#f472b6" stroke-width="1.5" marker-end="url(#arrowPink)"/>
      <text x="755" y="183" fill="#f472b6" font-size="7" opacity=".85" font-style="italic">daily digest</text>

      <g class="pn" data-tip="The lab's human discussion channel. Receives the daily digest, and lab members discuss, ask questions, and share reactions. share-to-minty also watches this channel." style="cursor:pointer" transform="translate(633,208)">
        <rect width="180" height="58" fill="#0f1520" stroke="#2ec4b6" stroke-width="1.5"/>
        <text x="90" y="18" text-anchor="middle" fill="#2ec4b6" font-size="11" font-weight="700">#mint-community</text>
        <text x="90" y="33" text-anchor="middle" fill="#94a3b8" font-size="8">Human discussion channel</text>
        <text x="90" y="46" text-anchor="middle" fill="#64748b" font-size="8">Daily digest + Seth &amp; lab Q&amp;A</text>
      </g>
      <g class="pn" data-tip="Lab members discuss the daily digest, ask questions about papers, and share their own finds. Discussion threads loop back into the pipeline via share-to-minty." style="cursor:pointer" transform="translate(846,218)">
        <rect width="100" height="38" fill="url(#nodeGrad)" stroke="#fbbf24" stroke-dasharray="4,3"/>
        <text x="50" y="16" text-anchor="middle" fill="#fbbf24" font-size="9" font-weight="600">Lab Members</text>
        <text x="50" y="30" text-anchor="middle" fill="#64748b" font-size="8">Discussion &amp; Q&amp;A</text>
      </g>
      <line x1="846" y1="237" x2="813" y2="237" stroke="#fbbf24" stroke-width="1" stroke-dasharray="3,3" marker-end="url(#arrowOrange)"/>

      <text x="723" y="276" text-anchor="middle" fill="#f59e0b" font-size="7" opacity=".75" font-style="italic">share-to-minty also watches</text>

      <line x1="633" y1="245" x2="605" y2="245" stroke="#2ec4b6" stroke-width="1.5"/>
      <line x1="605" y1="245" x2="605" y2="152" stroke="#2ec4b6" stroke-width="1.5"/>
      <line x1="605" y1="152" x2="580" y2="152" stroke="#2ec4b6" stroke-width="1.5" marker-end="url(#arrowGreen)"/>

      <!-- ===== ROW 2: Paper pipeline ===== -->
      <line x1="510" y1="170" x2="510" y2="225" stroke="#a78bfa" stroke-width="1.5" marker-end="url(#arrowPurple)"/>

      <g class="pn" data-tip="Polls #firehose every 5 minutes for URLs without attached PDFs. Tries programmatic download (arXiv, bioRxiv, OpenReview, direct links), then falls back to a sandboxed Claude agent for harder cases." style="cursor:pointer" transform="translate(440,228)">
        <rect width="140" height="50" fill="url(#nodeGrad)" stroke="#a78bfa" stroke-width="1.5"/>
        <text x="70" y="19" text-anchor="middle" fill="#a78bfa" font-size="10" font-weight="700">news-pdf-bot</text>
        <text x="70" y="33" text-anchor="middle" fill="#94a3b8" font-size="8">Download PDFs + markdown</text>
        <text x="70" y="44" text-anchor="middle" fill="#64748b" font-size="8">+ date markers</text>
      </g>
      <line x1="510" y1="278" x2="510" y2="303" stroke="#a78bfa" stroke-width="1.5" marker-end="url(#arrowPurple)"/>

      <g class="pn" data-tip="Slack channel where downloaded PDFs and conversion notifications are posted. Papers land here with metadata before being picked up by the corpus ingestion pipeline." style="cursor:pointer" transform="translate(450,306)">
        <rect width="120" height="38" fill="#0f1520" stroke="#fbbf24" stroke-width="1"/>
        <text x="60" y="15" text-anchor="middle" fill="#fbbf24" font-size="10" font-weight="700">#papers</text>
        <text x="60" y="30" text-anchor="middle" fill="#94a3b8" font-size="8">PDFs + notifications</text>
      </g>
      <line x1="510" y1="344" x2="510" y2="370" stroke="#2dd4bf" stroke-width="1.5" marker-end="url(#arrowTeal)"/>

      <g class="pn" data-tip="Unified 11-stage ingestion pipeline: download, rename, markdown conversion (6-tier cascade), embed (Voyage 2048d), enrich (CrossRef/Semantic Scholar), analyze (41 questions via LLM), RAPTOR summaries, verify, Drive upload, Zotero catalog, Slack report." style="cursor:pointer" transform="translate(440,373)">
        <rect width="140" height="50" fill="url(#nodeGrad)" stroke="#2dd4bf" stroke-width="1.5"/>
        <text x="70" y="19" text-anchor="middle" fill="#2dd4bf" font-size="10" font-weight="700">corpus-ingest</text>
        <text x="70" y="33" text-anchor="middle" fill="#94a3b8" font-size="8">Unified pipeline</text>
        <text x="70" y="44" text-anchor="middle" fill="#64748b" font-size="8">10-stage ingestion</text>
      </g>
      <line x1="510" y1="423" x2="510" y2="470" stroke="#2dd4bf" stroke-width="1.5" marker-end="url(#arrowTeal)"/>

      <g class="pn" data-tip="Vector database holding ~2,200 papers with 48 embedding dimensions per document (each 2048d via Voyage), 154K text chunks, 41 semantic analysis dimensions, 29 topic clusters, and 11,570 pre-computed similarity pairs." style="cursor:pointer" transform="translate(435,473)">
        <rect width="150" height="52" fill="url(#nodeGrad)" stroke="#2dd4bf" stroke-width="1.5"/>
        <text x="75" y="17" text-anchor="middle" fill="#2dd4bf" font-size="10" font-weight="700">LanceDB Corpus</text>
        <text x="75" y="31" text-anchor="middle" fill="#94a3b8" font-size="8">~2,200 papers</text>
        <text x="75" y="43" text-anchor="middle" fill="#64748b" font-size="8">41 semantic dimensions</text>
      </g>

      <line x1="510" y1="525" x2="510" y2="555" stroke="#22d3ee" stroke-width="1.5" marker-end="url(#arrowBlue)"/>

      <g class="pn" data-tip="Slack bot (@Minty) offering 7 search modes: fast search, deep review, catch me up, semantic similarity, dimension search, chunk search, and unified multi-modal search with Reciprocal Rank Fusion." style="cursor:pointer" transform="translate(415,558)">
        <rect width="190" height="52" fill="url(#nodeGrad)" stroke="#22d3ee" stroke-width="1.5"/>
        <text x="95" y="17" text-anchor="middle" fill="#22d3ee" font-size="10" font-weight="700">corpus-agent</text>
        <text x="95" y="31" text-anchor="middle" fill="#94a3b8" font-size="8">@Minty &#x2022; 7 modes &#x2022; News Search</text>
        <text x="95" y="43" text-anchor="middle" fill="#64748b" font-size="8">Deep Review &#x2022; Catch Me Up &#x2022; more</text>
      </g>

      <!-- ===== BOTTOM-LEFT: Background services ===== -->
      <g class="pn" data-tip="Always-on infrastructure: minty-search (Slack semantic search), slack-index (message indexing every 4h), workspace-index (file indexing every 6h), rclone-sync (Drive backups), and cli-health-probe (daemon monitoring)." style="cursor:pointer" transform="translate(20,460)">
        <rect width="180" height="190" fill="url(#nodeGrad)" stroke="rgba(255,255,255,0.1)"/>
        <text x="90" y="18" text-anchor="middle" fill="#94a3b8" font-size="8" font-weight="600">BACKGROUND SERVICES</text>
        <text x="90" y="40" text-anchor="middle" fill="#818cf8" font-size="9" font-weight="600">minty-search</text>
        <text x="90" y="52" text-anchor="middle" fill="#64748b" font-size="8">@minty-search &#x2022; Slack search</text>
        <text x="90" y="64" text-anchor="middle" fill="#64748b" font-size="8">Multi-query RRF &#x2022; Agentic</text>
        <text x="90" y="84" text-anchor="middle" fill="#818cf8" font-size="9" font-weight="600">slack-index</text>
        <text x="90" y="96" text-anchor="middle" fill="#64748b" font-size="8">Every 4h &#x2192; ChromaDB</text>
        <text x="90" y="116" text-anchor="middle" fill="#818cf8" font-size="9" font-weight="600">workspace-index</text>
        <text x="90" y="128" text-anchor="middle" fill="#64748b" font-size="8">Every 6h &#x2192; ChromaDB</text>
        <text x="90" y="148" text-anchor="middle" fill="#818cf8" font-size="9" font-weight="600">rclone-sync</text>
        <text x="90" y="160" text-anchor="middle" fill="#64748b" font-size="8">Drive sync + backups</text>
        <text x="90" y="180" text-anchor="middle" fill="#818cf8" font-size="9" font-weight="600">cli-health-probe</text>
      </g>

      <!-- ===== Animated dots ===== -->
      <g opacity="0" filter="url(#glow)">
        <image href="/mintresearch.org/assets/minty-teal.png" xlink:href="/mintresearch.org/assets/minty-teal.png" x="-9" y="-10" width="18" height="20" style="image-rendering:pixelated"/>
        <animateTransform attributeName="transform" type="translate" dur="12s" begin="indefinite" repeatCount="indefinite" calcMode="linear"
          keyTimes="0;0.01;0.05;0.09;0.12;0.16;0.19;0.22;0.25;0.28;0.32;0.34;0.38;0.41;0.43;0.47;0.49;0.50;0.51;0.57;0.62;0.68;0.76;0.84;0.93;0.97;1"
          values="88,39;88,39;243,39;379,39;489,39;617,39;617,85;510,85;510,137;580,130;723,133;723,158;723,237;633,245;605,245;605,152;580,152;510,152;510,170;510,253;510,325;510,398;510,499;510,584;510,584;510,584;88,39"/>
        <animate attributeName="opacity" dur="12s" begin="indefinite" repeatCount="indefinite" calcMode="linear"
          keyTimes="0;0.01;0.02;0.93;0.97;1"
          values="0;0;0.9;0.9;0;0"/>
      </g>

      <circle cx="100" cy="129" r="3.5" fill="#f59e0b" opacity="0">
        <animate attributeName="cx" dur="12s" begin="indefinite" repeatCount="indefinite" calcMode="linear"
          keyTimes="0;0.09;0.10;0.14;0.18;0.22;0.25;1"
          values="100;100;100;268;333;440;510;510"/>
        <animate attributeName="cy" dur="12s" begin="indefinite" repeatCount="indefinite" calcMode="linear"
          keyTimes="0;0.09;0.10;0.14;0.18;0.22;0.25;1"
          values="129;129;129;129;129;129;137;137"/>
        <animate attributeName="opacity" dur="12s" begin="indefinite" repeatCount="indefinite" calcMode="linear"
          keyTimes="0;0.09;0.10;0.14;0.20;0.24;0.25;1"
          values="0;0;0.9;0.9;0.9;0.4;0;0"/>
      </circle>

      <circle cx="896" cy="237" r="3" fill="#fbbf24" opacity="0">
        <animate attributeName="cx" dur="12s" begin="indefinite" repeatCount="indefinite" calcMode="linear"
          keyTimes="0;0.28;0.29;0.32;0.35;0.37;0.38;1"
          values="896;896;896;846;813;750;723;723"/>
        <animate attributeName="opacity" dur="12s" begin="indefinite" repeatCount="indefinite" calcMode="linear"
          keyTimes="0;0.28;0.29;0.32;0.35;0.37;0.38;1"
          values="0;0;0.9;0.9;0.9;0.4;0;0"/>
      </circle>
    </svg>
  </div>

  <div class="pipeline-mobile">
    <svg viewBox="0 0 450 750" width="100%" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" style="font-family:'JetBrains Mono',monospace" data-anim-delayed>
      <defs>
        <marker id="mArrCyan" markerWidth="7" markerHeight="5" refX="7" refY="2.5" orient="auto"><path d="M0,0 L7,2.5 L0,5" fill="#22d3ee"/></marker>
        <marker id="mArrGreen" markerWidth="7" markerHeight="5" refX="7" refY="2.5" orient="auto"><path d="M0,0 L7,2.5 L0,5" fill="#2ec4b6"/></marker>
        <marker id="mArrAmber" markerWidth="7" markerHeight="5" refX="7" refY="2.5" orient="auto"><path d="M0,0 L7,2.5 L0,5" fill="#fbbf24"/></marker>
        <marker id="mArrOrange" markerWidth="7" markerHeight="5" refX="7" refY="2.5" orient="auto"><path d="M0,0 L7,2.5 L0,5" fill="#f59e0b"/></marker>
        <marker id="mArrPink" markerWidth="7" markerHeight="5" refX="7" refY="2.5" orient="auto"><path d="M0,0 L7,2.5 L0,5" fill="#f472b6"/></marker>
        <marker id="mArrPurple" markerWidth="7" markerHeight="5" refX="7" refY="2.5" orient="auto"><path d="M0,0 L7,2.5 L0,5" fill="#a78bfa"/></marker>
        <marker id="mArrTeal" markerWidth="7" markerHeight="5" refX="7" refY="2.5" orient="auto"><path d="M0,0 L7,2.5 L0,5" fill="#2dd4bf"/></marker>
        <marker id="mArrBlue" markerWidth="7" markerHeight="5" refX="7" refY="2.5" orient="auto"><path d="M0,0 L7,2.5 L0,5" fill="#22d3ee"/></marker>
        <linearGradient id="mGrad" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#1a1f2c"/><stop offset="100%" stop-color="#13171f"/></linearGradient>
        <filter id="mGlow"><feGaussianBlur stdDeviation="3" result="b"/><feFlood flood-color="#2ec4b6" flood-opacity="0.3" result="c"/><feComposite in="c" in2="b" operator="in" result="cb"/><feMerge><feMergeNode in="cb"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
      </defs>

      <!-- ROW 0 -->
