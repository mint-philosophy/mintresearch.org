<!-- ============ PUBLICATIONS ============ -->
<Section id="publications" num="03">
  <h2><span class="cmd-prefix"><span class="cmd-name">ls</span> <span class="cmd-flag">-la</span> <span class="cmd-path">publications/</span></span></h2>

  <TerminalPicker items={publications} label="publications" />
</Section>


<!-- ============ EVENTS ============ -->
<Section id="events" num="04">
  <h2><span class="cmd-prefix"><span class="cmd-name">ls</span> <span class="cmd-flag">-la</span> <span class="cmd-path">events/</span></span></h2>

  <TerminalPicker items={events} label="events" />
</Section>


<!-- ============ NEWS ============ -->
<Section id="news" num="05">
  <h2><span class="cmd-prefix"><span class="cmd-name">tail</span> <span class="cmd-flag">-f</span> <span class="cmd-path">news.log</span></span></h2>

  <TerminalPicker items={news} label="news" />
</Section>

<!-- ============ CONTACT ============ -->
<Section id="contact" num="06">
  <h2><span class="cmd-prefix"><span class="cmd-name">mail</span> <span class="cmd-flag">-s</span> <span class="cmd-arg">"inquiry"</span> <span class="cmd-path">contact@mintresearch.org</span></span></h2>
  <p class="contact-intro">Get in touch — we welcome inquiries about research collaborations, lab visits, and speaking invitations.</p>

  <form class="terminal-form" action="https://formsubmit.co/f3ed156ef75fc12f2395ba0d338cc6ce" method="POST">
    <!-- Formsubmit configuration -->
    <input type="hidden" name="_subject" value="New inquiry from mintresearch.org">
    <input type="hidden" name="_captcha" value="true">
    <input type="hidden" name="_next" value="https://mintresearch.org">
    <input type="hidden" name="_template" value="table">
    <!-- Honeypot -->
    <input type="text" name="_honey" style="display:none">

    <div class="tf-field">
      <label class="tf-label" for="contact-name"><span class="tf-prompt">$</span> name</label>
      <input type="text" id="contact-name" name="name" required autocomplete="name" placeholder="your name">
    </div>

    <div class="tf-field">
      <label class="tf-label" for="contact-email"><span class="tf-prompt">$</span> email</label>
      <input type="email" id="contact-email" name="email" required autocomplete="email" placeholder="you@institution.edu">
    </div>

    <div class="tf-field">
      <label class="tf-label" for="contact-affiliation"><span class="tf-prompt">$</span> affiliation <span class="tf-optional">(optional)</span></label>
      <input type="text" id="contact-affiliation" name="affiliation" autocomplete="organization" placeholder="university or organisation">
    </div>

    <div class="tf-field">
      <label class="tf-label" for="contact-message"><span class="tf-prompt">$</span> message</label>
      <textarea id="contact-message" name="message" required rows="5" placeholder="your message here..."></textarea>
    </div>

    <button type="submit" class="tf-submit"><span class="tf-prompt">$</span> send_message</button>
  </form>
</Section>


<!-- ============ FOOTER ============ -->
<section class="no-brackets" style="padding: 40px 48px; text-align: center;">
  <p style="font-size: 11px; color: var(--text-3); max-width: 600px; margin: 0 auto 16px;">
    We acknowledge the Traditional Custodians of Country throughout Australia, and their continuing connection to culture, community, land, sea and sky. We pay our respects to Elders past, present and future.
  </p>
  <p style="font-size: 11px; color: var(--text-3);">
    &copy; MINT Research Lab &middot; Johns Hopkins University
  </p>
  <p style="font-size: 12px; color: var(--green); margin-top: 16px; opacity: 0.5;">
    exit 0
  </p>
</section>

